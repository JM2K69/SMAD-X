<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Window principale -->
    <Style Selector="Window">
        <Setter Property="Background" Value="#1E1E1E"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <!-- Menu principal -->
    <Style Selector="Menu">
        <Setter Property="Background" Value="#1E1E1E"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <Style Selector="MenuItem">
        <Setter Property="Background" Value="#1E1E1E"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <Style Selector="MenuItem:pointerover /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="#3F3F46"/>
    </Style>

    <Style Selector="MenuItem:selected /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="#3F3F46"/>
    </Style>

    <!-- TreeView - styles prioritaires -->
    <Style Selector="TreeView">
        <Setter Property="Background" Value="#1E1E1E"/>
        <Setter Property="Foreground" Value="#E0E0E0"/>
    </Style>

    <Style Selector="TreeView Border">
        <Setter Property="Background" Value="#1E1E1E"/>
    </Style>

    <Style Selector="TreeViewItem">
        <Setter Property="Background" Value="#1E1E1E"/>
        <Setter Property="Foreground" Value="#E0E0E0"/>
    </Style>

    <Style Selector="TreeViewItem:selected">
        <Setter Property="Background" Value="#094771"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <Style Selector="TreeViewItem:selected /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="#094771"/>
    </Style>

    <Style Selector="TreeViewItem /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="#1E1E1E"/>
    </Style>

    <!-- StackPanel dans la toolbar -->
    <Style Selector="StackPanel">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style Selector="Grid StackPanel">
        <Setter Property="Background" Value="#2D2D30"/>
    </Style>

    <!-- Borders -->
    <Style Selector="Border">
        <Setter Property="Background" Value="#252526"/>
        <Setter Property="BorderBrush" Value="#3F3F46"/>
    </Style>

    <!-- TextBlocks -->
    <Style Selector="TextBlock">
        <Setter Property="Foreground" Value="#E0E0E0"/>
    </Style>

    <!-- TextBox -->
    <Style Selector="TextBox">
        <Setter Property="Background" Value="#2D2D30"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="BorderBrush" Value="#3F3F46"/>
        <Setter Property="CaretBrush" Value="#FFFFFF"/>
    </Style>

    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="#007ACC"/>
    </Style>

    <Style Selector="TextBox:readonly">
        <Setter Property="Background" Value="#333337"/>
        <Setter Property="Foreground" Value="#A0A0A0"/>
    </Style>

    <!-- Buttons -->
    <Style Selector="Button">
        <Setter Property="Background" Value="#3F3F46"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="BorderBrush" Value="#3F3F46"/>
    </Style>

    <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#505050"/>
    </Style>

    <Style Selector="Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#2D2D30"/>
    </Style>

    <!-- ComboBox -->
    <Style Selector="ComboBox">
        <Setter Property="Background" Value="#2D2D30"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="BorderBrush" Value="#3F3F46"/>
    </Style>

    <Style Selector="ComboBox:pointerover /template/ Border#Background">
        <Setter Property="BorderBrush" Value="#007ACC"/>
    </Style>

    <Style Selector="ComboBox:focus /template/ Border#Background">
        <Setter Property="BorderBrush" Value="#007ACC"/>
    </Style>

    <Style Selector="ComboBoxItem">
        <Setter Property="Background" Value="#2D2D30"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#3F3F46"/>
    </Style>

    <Style Selector="ComboBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#094771"/>
    </Style>

    <!-- ListBox -->
    <Style Selector="ListBox">
        <Setter Property="Background" Value="#252526"/>
        <Setter Property="Foreground" Value="#E0E0E0"/>
    </Style>

    <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#094771"/>
    </Style>

    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#3F3F46"/>
    </Style>

    <!-- Slider -->
    <Style Selector="Slider">
        <Setter Property="Foreground" Value="#007ACC"/>
    </Style>

    <!-- GridSplitter -->
    <Style Selector="GridSplitter">
        <Setter Property="Background" Value="#3F3F46"/>
    </Style>

    <!-- ScrollViewer -->
    <Style Selector="ScrollViewer">
        <Setter Property="Background" Value="#252526"/>
    </Style>

    <!-- ContentControl -->
    <Style Selector="ContentControl">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <!-- Separator -->
    <Style Selector="Separator">
        <Setter Property="Background" Value="#3F3F46"/>
    </Style>
</Styles>
