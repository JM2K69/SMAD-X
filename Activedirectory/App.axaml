<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SMADX.App"
             xmlns:local="using:SMADX"
             xmlns:converters="using:SMADX.Converters"
             xmlns:helpers="using:SMADX.Helpers"
             RequestedThemeVariant="Light">

    <Application.Resources>
        <converters:BoolToStringConverter x:Key="BoolToStringConverter"/>
        <converters:MarkdownConverter x:Key="MarkdownConverter"/>
        <helpers:LocalizationProxy x:Key="Loc"/>
    </Application.Resources>

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://SMAD-X/Styles/LightTheme.axaml"/>
    </Application.Styles>
</Application>
