<Styles xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!--
		AppStyles.axaml — surcharges applicatives au-dessus de FluentTheme.
		Les couleurs sensibles au thème utilisent ThemeVariant pour éviter
		tout sélecteur générique qui contaminerait les composants internes.
	-->

	<!-- ══════════════════════════════════════════════════════════
		 RESSOURCES PAR VARIANTE DE THÈME
		 ══════════════════════════════════════════════════════════ -->
	<Styles.Resources>
		<ResourceDictionary>
			<ResourceDictionary.ThemeDictionaries>

				<!-- ── Thème Clair ───────────────────────────────── -->
				<ResourceDictionary x:Key="Light">
					<SolidColorBrush x:Key="AppAccentBrush"         Color="#007ACC"/>
					<SolidColorBrush x:Key="AppSelectionBrush"      Color="#CCE4F7"/>
					<SolidColorBrush x:Key="AppTreeBgBrush"         Color="#FFFFFF"/>
					<SolidColorBrush x:Key="AppTreeFgBrush"         Color="#1E1E1E"/>
					<SolidColorBrush x:Key="AppSelectedItemBrush"   Color="#CCE4F7"/>
					<SolidColorBrush x:Key="AppSelectedItemFgBrush" Color="#000000"/>
					<SolidColorBrush x:Key="AppToolbarBgBrush"      Color="#F0F0F0"/>
					<SolidColorBrush x:Key="AppTierFgBrush"         Color="#005F9E"/>
					<SolidColorBrush x:Key="AppSeparatorBrush"      Color="#CCCCCC"/>
					<SolidColorBrush x:Key="AppRelationsBtnBgBrush" Color="#0078D4"/>
					<SolidColorBrush x:Key="AppRelationsBtnFgBrush" Color="#FFFFFF"/>
					<SolidColorBrush x:Key="AppGraphBtnBgBrush"     Color="#6B3FA0"/>
					<SolidColorBrush x:Key="AppGraphBtnFgBrush"     Color="#FFFFFF"/>
				</ResourceDictionary>

				<!-- ── Thème Sombre ──────────────────────────────── -->
				<ResourceDictionary x:Key="Dark">
					<SolidColorBrush x:Key="AppAccentBrush"         Color="#007ACC"/>
					<SolidColorBrush x:Key="AppSelectionBrush"      Color="#094771"/>
					<SolidColorBrush x:Key="AppTreeBgBrush"         Color="#1E1E1E"/>
					<SolidColorBrush x:Key="AppTreeFgBrush"         Color="#E0E0E0"/>
					<SolidColorBrush x:Key="AppSelectedItemBrush"   Color="#094771"/>
					<SolidColorBrush x:Key="AppSelectedItemFgBrush" Color="#FFFFFF"/>
					<SolidColorBrush x:Key="AppToolbarBgBrush"      Color="#2D2D30"/>
					<SolidColorBrush x:Key="AppTierFgBrush"         Color="#7FFF9A"/>
					<SolidColorBrush x:Key="AppSeparatorBrush"      Color="#3F3F46"/>
					<SolidColorBrush x:Key="AppRelationsBtnBgBrush" Color="#094771"/>
					<SolidColorBrush x:Key="AppRelationsBtnFgBrush" Color="#FFFFFF"/>
					<SolidColorBrush x:Key="AppGraphBtnBgBrush"     Color="#4B3580"/>
					<SolidColorBrush x:Key="AppGraphBtnFgBrush"     Color="#FFFFFF"/>
				</ResourceDictionary>

			</ResourceDictionary.ThemeDictionaries>
		</ResourceDictionary>
	</Styles.Resources>

	<!-- ══════════════════════════════════════════════════════════
		 TREEVIEW
		 ══════════════════════════════════════════════════════════ -->
	<Style Selector="TreeView">
		<Setter Property="Background" Value="{DynamicResource AppTreeBgBrush}"/>
	</Style>

	<Style Selector="TreeViewItem">
		<Setter Property="Foreground" Value="{DynamicResource AppTreeFgBrush}"/>
	</Style>

	<Style Selector="TreeViewItem:selected /template/ Border#PART_LayoutRoot">
		<Setter Property="Background" Value="{DynamicResource AppSelectedItemBrush}"/>
	</Style>

	<Style Selector="TreeViewItem:selected > Border > StackPanel TextBlock">
		<Setter Property="Foreground" Value="{DynamicResource AppSelectedItemFgBrush}"/>
	</Style>

	<!-- ══════════════════════════════════════════════════════════
		 TOOLBAR STACKPANEL
		 ══════════════════════════════════════════════════════════ -->
	<Style Selector="StackPanel#Toolbar">
		<Setter Property="Background" Value="{DynamicResource AppToolbarBgBrush}"/>
	</Style>

	<!-- ══════════════════════════════════════════════════════════
		 SÉPARATEUR
		 ══════════════════════════════════════════════════════════ -->
	<Style Selector="Separator">
		<Setter Property="Background" Value="{DynamicResource AppSeparatorBrush}"/>
	</Style>

	<!-- ══════════════════════════════════════════════════════════
		 FOCUS ACCENT
		 ══════════════════════════════════════════════════════════ -->
	<Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
		<Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
	</Style>

	<Style Selector="ComboBox:pointerover /template/ Border#Background">
		<Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
	</Style>

	<Style Selector="ComboBox:focus /template/ Border#Background">
		<Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
	</Style>

	<Style Selector="Slider">
		<Setter Property="Foreground" Value="{DynamicResource AppAccentBrush}"/>
	</Style>

	<!-- ══════════════════════════════════════════════════════════
		 CONTEXTMENU — force le foreground via ThemeVariant
		 pour éviter la contamination après fermeture de GraphWindow
		 ══════════════════════════════════════════════════════════ -->
	<Style Selector="ContextMenu">
		<Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
	</Style>

	<Style Selector="ContextMenu MenuItem">
		<Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
	</Style>

	<!-- ══════════════════════════════════════════════════════════
		 TOOLBAR BUTTONS — empêche FluentTheme de propager
		 ButtonForegroundPointerOver vers les TextBlock emoji/label.
		 Trois niveaux de ciblage pour couvrir tous les cas :
		   1. ContentPresenter du template au :pointerover/:pressed
		   2. Tous les TextBlock enfants (hors template)
		   3. Cas normal (pas de hover) pour baseline correcte
		 ══════════════════════════════════════════════════════════ -->
	<Style Selector="StackPanel#Toolbar Button">
		<Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
	</Style>
	<Style Selector="StackPanel#Toolbar Button:pointerover">
		<Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
	</Style>
	<Style Selector="StackPanel#Toolbar Button:pressed">
		<Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
	</Style>
	<Style Selector="StackPanel#Toolbar Button /template/ ContentPresenter">
		<Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
	</Style>
	<Style Selector="StackPanel#Toolbar Button:pointerover /template/ ContentPresenter">
		<Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
	</Style>
	<Style Selector="StackPanel#Toolbar Button:pressed /template/ ContentPresenter">
		<Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
	</Style>
	<!-- Cible directement les TextBlocks du contenu (emoji + label) -->
	<Style Selector="StackPanel#Toolbar Button TextBlock">
		<Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
	</Style>

	<!-- Relations / Graph : foreground dédié selon le thème -->
	<Style Selector="StackPanel#Toolbar Button.BtnRelations">
		<Setter Property="Foreground" Value="{DynamicResource AppRelationsBtnFgBrush}"/>
	</Style>
	<Style Selector="StackPanel#Toolbar Button.BtnRelations:pointerover">
		<Setter Property="Foreground" Value="{DynamicResource AppRelationsBtnFgBrush}"/>
	</Style>
	<Style Selector="StackPanel#Toolbar Button.BtnRelations:pressed">
		<Setter Property="Foreground" Value="{DynamicResource AppRelationsBtnFgBrush}"/>
	</Style>
	<Style Selector="StackPanel#Toolbar Button.BtnRelations /template/ ContentPresenter">
		<Setter Property="Foreground" Value="{DynamicResource AppRelationsBtnFgBrush}"/>
	</Style>
	<Style Selector="StackPanel#Toolbar Button.BtnRelations:pointerover /template/ ContentPresenter">
		<Setter Property="Foreground" Value="{DynamicResource AppRelationsBtnFgBrush}"/>
	</Style>
	<Style Selector="StackPanel#Toolbar Button.BtnRelations TextBlock">
		<Setter Property="Foreground" Value="{DynamicResource AppRelationsBtnFgBrush}"/>
	</Style>
	<Style Selector="StackPanel#Toolbar Button.BtnGraph">
		<Setter Property="Foreground" Value="{DynamicResource AppGraphBtnFgBrush}"/>
	</Style>
	<Style Selector="StackPanel#Toolbar Button.BtnGraph:pointerover">
		<Setter Property="Foreground" Value="{DynamicResource AppGraphBtnFgBrush}"/>
	</Style>
	<Style Selector="StackPanel#Toolbar Button.BtnGraph:pressed">
		<Setter Property="Foreground" Value="{DynamicResource AppGraphBtnFgBrush}"/>
	</Style>
	<Style Selector="StackPanel#Toolbar Button.BtnGraph /template/ ContentPresenter">
		<Setter Property="Foreground" Value="{DynamicResource AppGraphBtnFgBrush}"/>
	</Style>
	<Style Selector="StackPanel#Toolbar Button.BtnGraph:pointerover /template/ ContentPresenter">
		<Setter Property="Foreground" Value="{DynamicResource AppGraphBtnFgBrush}"/>
	</Style>
	<Style Selector="StackPanel#Toolbar Button.BtnGraph TextBlock">
		<Setter Property="Foreground" Value="{DynamicResource AppGraphBtnFgBrush}"/>
	</Style>

</Styles>
