<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SMADX.ViewModels"
        xmlns:services="using:SMADX.Services"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
        x:Class="SMADX.Views.TierConfigurationWindow"
        x:DataType="vm:TierConfigurationViewModel"
        x:Name="TierConfigWindow"
        Title="{Binding Source={StaticResource Loc}, Path=TierConfigTitle}"
        Icon="/Assets/icone.ico"
        Width="800" Height="600"
        WindowStartupLocation="CenterOwner">

    <Design.DataContext>
        <vm:TierConfigurationViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto" Margin="20" DataContext="{StaticResource Loc}">
        <!-- Titre -->
        <TextBlock Grid.Row="0" 
                   Text="{Binding TierConfigHeader}" 
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Contenu principal -->
        <Grid Grid.Row="1" ColumnDefinitions="*,20,*">
            <!-- Liste des tiers existants -->
            <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Padding="10">
                <Grid RowDefinitions="Auto,*,Auto">
                    <TextBlock Grid.Row="0" 
                               Text="{Binding TierConfigExistingTiers}" 
                               FontWeight="SemiBold" Margin="0,0,0,10"/>

                    <ListBox Grid.Row="1" ItemsSource="{Binding #TierConfigWindow.DataContext.Tiers}"
                             SelectedItem="{Binding #TierConfigWindow.DataContext.SelectedTier, Mode=TwoWay}"
                             Margin="0,0,0,10"
                             x:Name="TiersListBox">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="LightGray" BorderThickness="1" 
                                        Padding="10" Margin="0,5">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="2" Margin="0,0,10,0">
                                            <Button Content="▲" Width="30" Height="25" 
                                                    Click="OnMoveUpClick"
                                                    FontSize="10" Padding="0"/>
                                            <Button Content="▼" Width="30" Height="25" 
                                                    Click="OnMoveDownClick"
                                                    FontSize="10" Padding="0"/>
                                        </StackPanel>
                                        <Grid Grid.Column="1" RowDefinitions="Auto,Auto,Auto">
                                            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10">
                                                <TextBlock Text="{Binding Name}" 
                                                           FontWeight="Bold" FontSize="14"/>
                                                <Border Width="30" Height="20" 
                                                        Background="{Binding Color}"
                                                        BorderBrush="Black" BorderThickness="1"/>
                                            </StackPanel>
                                            <TextBlock Grid.Row="1" Text="{Binding Description}" 
                                                       TextWrapping="Wrap" Margin="0,5,0,0"
                                                       FontSize="12" Foreground="Gray"/>
                                            <TextBlock Grid.Row="2" 
                                                       Text="{Binding Level, StringFormat='Level: {0}'}"
                                                       FontSize="11" Foreground="DarkGray" Margin="0,3,0,0"/>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10">
                        <Button Content="{Binding TierConfigDelete}" Command="{Binding #TierConfigWindow.DataContext.RemoveTierCommand}"
                                IsEnabled="{Binding #TierConfigWindow.DataContext.SelectedTier, Converter={x:Static ObjectConverters.IsNotNull}}"
                                Padding="15,5"/>
                        <Button Content="{Binding TierConfigReset}" Command="{Binding #TierConfigWindow.DataContext.ResetToDefaultsCommand}"
                                Padding="15,5"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Ajout d'un nouveau tier -->
            <Border Grid.Column="2" BorderBrush="Gray" BorderThickness="1" Padding="10">
                <Grid RowDefinitions="Auto,*,Auto">
                    <TextBlock Grid.Row="0" 
                               Text="{Binding TierConfigAddNew}" 
                               FontWeight="SemiBold" Margin="0,0,0,10"/>

                    <StackPanel Grid.Row="1" Spacing="15">
                        <StackPanel Spacing="5">
                            <TextBlock Text="{Binding TierConfigName}" FontWeight="SemiBold"/>
                            <TextBox Text="{Binding #TierConfigWindow.DataContext.NewTierName, Mode=TwoWay}"
                                     PlaceholderText="{Binding TierConfigNamePlaceholder}"/>
                        </StackPanel>

                        <StackPanel Spacing="5">
                            <TextBlock Text="{Binding TierConfigColor}" FontWeight="SemiBold"/>
                            <Grid ColumnDefinitions="*,50,100">
                                <TextBox Grid.Column="0" Text="{Binding #TierConfigWindow.DataContext.NewTierColor, Mode=TwoWay}"
                                         PlaceholderText="{Binding TierConfigColorPlaceholder}"/>
                                <Border Grid.Column="1" Background="{Binding #TierConfigWindow.DataContext.NewTierColor}"
                                        BorderBrush="Black" BorderThickness="1" Margin="5,0"/>
                                <Button Grid.Column="2" Content="{Binding TierConfigColorSelect}" 
                                        Click="OnSelectColorClick" Padding="5"/>
                            </Grid>
                            <TextBlock Text="{Binding TierConfigColorExamples}"
                                       FontSize="10" Foreground="Gray"/>
                        </StackPanel>

                        <StackPanel Spacing="5">
                            <TextBlock Text="{Binding TierConfigDescription}" FontWeight="SemiBold"/>
                            <TextBox Text="{Binding #TierConfigWindow.DataContext.NewTierDescription, Mode=TwoWay}"
                                     AcceptsReturn="True" Height="80" TextWrapping="Wrap"
                                     PlaceholderText="{Binding TierConfigDescriptionPlaceholder}"/>
                        </StackPanel>

                        <StackPanel Spacing="5">
                            <TextBlock Text="{Binding TierConfigPriority}" FontWeight="SemiBold"/>
                            <NumericUpDown Value="{Binding #TierConfigWindow.DataContext.NewTierLevel, Mode=TwoWay}"
                                          Minimum="0" Maximum="99" Width="150"
                                          HorizontalAlignment="Left"/>
                            <TextBlock Text="{Binding TierConfigPriorityHint}"
                                       FontSize="10" Foreground="Gray"/>
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Row="2" Content="{Binding TierConfigAdd}" Command="{Binding #TierConfigWindow.DataContext.AddTierCommand}"
                            HorizontalAlignment="Stretch" Padding="15,8"
                            Margin="0,10,0,0"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Boutons de bas de page -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Spacing="10" Margin="0,20,0,0">
            <Button Content="{Binding TierConfigClose}" Click="OnCloseClick" Padding="20,8"/>
        </StackPanel>
    </Grid>
</Window>
