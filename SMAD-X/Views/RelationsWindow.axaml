<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SMADX.ViewModels"
        xmlns:conv="using:SMADX.Converters"
        xmlns:services="using:SMADX.Services"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="SMADX.Views.RelationsWindow"
        x:DataType="vm:RelationsViewModel"
        x:Name="RelationsWindowRoot"
        Title="{Binding Source={StaticResource Loc}, Path=RelationsTitle}"
        Icon="/Assets/icone.ico"
        Width="860" Height="640"
        WindowStartupLocation="CenterOwner"
        CanResize="True">

    <Window.Resources>
        <conv:ObjectTypeToIconConverter x:Key="ObjectTypeToIconConverter"/>
    </Window.Resources>

    <Window.Styles>
        <!-- En-tête de colonne : s'adapte au thème -->
        <Style Selector="Border.RelHeader">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumBrush}"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
        <Style Selector="Border.RelHeader TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <!-- Ligne de données -->
        <Style Selector="Border.RelRow">
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
        <Style Selector="Border.RelRow TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
        </Style>
        <!-- Badge type : User / Computer / Group -->
        <Style Selector="Border.BadgeUser">
            <Setter Property="Background" Value="#1E5A9C"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="4,1"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>
        <Style Selector="Border.BadgeComputer">
            <Setter Property="Background" Value="#107C10"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="4,1"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>
        <Style Selector="Border.BadgeGroup">
            <Setter Property="Background" Value="#8764B8"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="4,1"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>
        <!-- Bouton Supprimer -->
        <Style Selector="Button.BtnDelete">
            <Setter Property="Background" Value="#C42B1C"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.BtnDelete:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#A4201A"/>
        </Style>
        <!-- Icônes emoji dans les ComboBox : force le rendu couleur Skia
             en fixant FontFamily directement sur le TextBlock, ce qui
             empêche l'héritage du Foreground de la sélection TabItem/ComboBoxItem
             de passer en mode monochrome. -->
        <Style Selector="TextBlock.EmojiIcon">
            <Setter Property="FontFamily" Value="Segoe UI Emoji"/>
        </Style>
        <Style Selector="ComboBoxItem:selected TextBlock.EmojiIcon">
            <Setter Property="FontFamily" Value="Segoe UI Emoji"/>
        </Style>
        <Style Selector="ComboBoxItem:pointerover TextBlock.EmojiIcon">
            <Setter Property="FontFamily" Value="Segoe UI Emoji"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="*,Auto">

        <TabControl Grid.Row="0" Margin="10"
                    SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">

            <!-- ===== ONGLET USER / COMPUTER → GROUP ===== -->
            <TabItem Header="{Binding Source={StaticResource Loc}, Path=RelationsTabUserGroup}">
                <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="8">

                    <Border Grid.Row="0" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                            BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,6">
                        <Grid ColumnDefinitions="*,30,*,10,Auto" RowDefinitions="Auto,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="User / Computer"
                                       FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="2"
                                       Text="{Binding Source={StaticResource Loc}, Path=RelationsLabelTargetGroup}"
                                       FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <ComboBox Grid.Row="1" Grid.Column="0"
                                      SelectedItem="{Binding MembershipSourceObject, Mode=TwoWay}"
                                      ItemsSource="{Binding AvailableUsers}"
                                      PlaceholderText="Choose a user or computer..."
                                      HorizontalAlignment="Stretch">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ADObjectSuggestion">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Classes="EmojiIcon" Text="{Binding Icon}" FontSize="14" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="→" FontSize="18"
                                       VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#0078D4"/>
                            <ComboBox Grid.Row="1" Grid.Column="2"
                                      SelectedItem="{Binding MembershipTargetObject, Mode=TwoWay}"
                                      ItemsSource="{Binding AvailableGroups}"
                                      PlaceholderText="{Binding Source={StaticResource Loc}, Path=RelationsChooseGroup}"
                                      HorizontalAlignment="Stretch">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ADObjectSuggestion">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Classes="EmojiIcon" Text="{Binding Icon}" FontSize="14" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <Button Grid.Row="1" Grid.Column="4"
                                    Content="{Binding Source={StaticResource Loc}, Path=RelationsAdd}"
                                    Command="{Binding #RelationsWindowRoot.DataContext.AddMembershipCommand}"
                                    Padding="12,6" Background="#0078D4" Foreground="White" VerticalAlignment="Bottom"/>
                        </Grid>
                    </Border>

                    <!-- En-têtes de colonnes -->
                    <Grid Grid.Row="1" ColumnDefinitions="80,160,160,*">
                        <Border Grid.Column="0" Classes="RelHeader"><TextBlock Text="Type"/></Border>
                        <Border Grid.Column="1" Classes="RelHeader"><TextBlock Text="User / Computer"/></Border>
                        <Border Grid.Column="2" Classes="RelHeader"><TextBlock Text="{Binding Source={StaticResource Loc}, Path=RelationsColGroup}"/></Border>
                        <Border Grid.Column="3" Classes="RelHeader"><TextBlock Text="{Binding Source={StaticResource Loc}, Path=RelationsColRelation}"/></Border>
                    </Grid>

                    <ListBox Grid.Row="2" ItemsSource="{Binding Memberships}" SelectedItem="{Binding SelectedMembership, Mode=TwoWay}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:RelationEntry">
                                <Grid ColumnDefinitions="80,160,160,*">
                                    <Border Grid.Column="0" Classes="RelRow">
                                        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                            <TextBlock Classes="EmojiIcon"
                                                       Text="{Binding SourceType, Converter={StaticResource ObjectTypeToIconConverter}}"
                                                       FontSize="14" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding SourceType}"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       Foreground="#4FC3F7" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Classes="RelRow"><TextBlock Text="{Binding Source}" TextTrimming="CharacterEllipsis"/></Border>
                                    <Border Grid.Column="2" Classes="RelRow"><TextBlock Text="{Binding Target}" TextTrimming="CharacterEllipsis"/></Border>
                                    <Border Grid.Column="3" Classes="RelRow"><TextBlock Text="{Binding RelationType}"/></Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
                        <Button Classes="BtnDelete"
                                Content="{Binding Source={StaticResource Loc}, Path=RelationsDelete}"
                                Command="{Binding #RelationsWindowRoot.DataContext.RemoveMembershipCommand}"
                                Padding="10,5"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ===== ONGLET GROUP → GROUP ===== -->
            <TabItem Header="{Binding Source={StaticResource Loc}, Path=RelationsTabGroupGroup}">
                <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="8">

                    <Border Grid.Row="0" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                            BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,6">
                        <Grid ColumnDefinitions="*,30,*,10,Auto" RowDefinitions="Auto,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="{Binding Source={StaticResource Loc}, Path=RelationsLabelGroupMember}"
                                       FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="2"
                                       Text="{Binding Source={StaticResource Loc}, Path=RelationsLabelGroupParent}"
                                       FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <ComboBox Grid.Row="1" Grid.Column="0"
                                      SelectedItem="{Binding NestingSourceObject, Mode=TwoWay}"
                                      ItemsSource="{Binding AvailableGroups}"
                                      PlaceholderText="{Binding Source={StaticResource Loc}, Path=RelationsChooseGroup}"
                                      HorizontalAlignment="Stretch">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ADObjectSuggestion">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Classes="EmojiIcon" Text="{Binding Icon}" FontSize="14" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="⊂" FontSize="18"
                                       VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#8764B8"/>
                            <ComboBox Grid.Row="1" Grid.Column="2"
                                      SelectedItem="{Binding NestingTargetObject, Mode=TwoWay}"
                                      ItemsSource="{Binding AvailableGroups}"
                                      PlaceholderText="{Binding Source={StaticResource Loc}, Path=RelationsChooseGroup}"
                                      HorizontalAlignment="Stretch">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ADObjectSuggestion">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Classes="EmojiIcon" Text="{Binding Icon}" FontSize="14" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <Button Grid.Row="1" Grid.Column="4"
                                    Content="{Binding Source={StaticResource Loc}, Path=RelationsAdd}"
                                    Command="{Binding #RelationsWindowRoot.DataContext.AddGroupNestingCommand}"
                                    Padding="12,6" Background="#8764B8" Foreground="White" VerticalAlignment="Bottom"/>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" ColumnDefinitions="200,200,*">
                        <Border Grid.Column="0" Classes="RelHeader"><TextBlock Text="{Binding Source={StaticResource Loc}, Path=RelationsColGroupMember}" FontWeight="SemiBold"/></Border>
                        <Border Grid.Column="1" Classes="RelHeader"><TextBlock Text="{Binding Source={StaticResource Loc}, Path=RelationsColGroupParent}" FontWeight="SemiBold"/></Border>
                        <Border Grid.Column="2" Classes="RelHeader"><TextBlock Text="{Binding Source={StaticResource Loc}, Path=RelationsColRelation}" FontWeight="SemiBold"/></Border>
                    </Grid>

                    <ListBox Grid.Row="2" ItemsSource="{Binding GroupNestings}" SelectedItem="{Binding SelectedGroupNesting, Mode=TwoWay}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:RelationEntry">
                                <Grid ColumnDefinitions="200,200,*">
                                    <Border Grid.Column="0" Classes="RelRow"><TextBlock Text="{Binding Source}" TextTrimming="CharacterEllipsis"/></Border>
                                    <Border Grid.Column="1" Classes="RelRow"><TextBlock Text="{Binding Target}" TextTrimming="CharacterEllipsis"/></Border>
                                    <Border Grid.Column="2" Classes="RelRow"><TextBlock Text="{Binding RelationType}"/></Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
                        <Button Classes="BtnDelete"
                                Content="{Binding Source={StaticResource Loc}, Path=RelationsDelete}"
                                Command="{Binding #RelationsWindowRoot.DataContext.RemoveGroupNestingCommand}"
                                Padding="10,5"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ===== ONGLET GPO LINKS ===== -->
            <TabItem Header="{Binding Source={StaticResource Loc}, Path=RelationsTabGpoLinks}">
                <Grid ColumnDefinitions="240,*" Margin="8" RowDefinitions="*">

                    <!-- Colonne gauche : TreeView hiérarchique des OUs -->
                    <Border Grid.Column="0"
                            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                            BorderThickness="1" CornerRadius="4" Margin="0,0,6,0">
                        <Grid RowDefinitions="Auto,*">
                            <Border Grid.Row="0" Classes="RelHeader" CornerRadius="4,4,0,0">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Classes="EmojiIcon" Text="📁" FontSize="13" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=RelationsLabelTargetOU}"
                                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ScrollViewer Grid.Row="1"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto">
                                <TreeView ItemsSource="{Binding OuTreeRoots}"
                                          SelectedItem="{Binding SelectedOuNode, Mode=TwoWay}"
                                          Margin="4">
                                    <TreeView.ItemTemplate>
                                        <TreeDataTemplate x:DataType="vm:OuTreeNode"
                                                          ItemsSource="{Binding Children}">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Classes="EmojiIcon" Text="{Binding Icon}" FontSize="13" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </TreeDataTemplate>
                                    </TreeView.ItemTemplate>
                                </TreeView>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- Colonne droite : sélection GPO + liste des liens -->
                    <Grid Grid.Column="1" RowDefinitions="Auto,Auto,*,Auto">

                        <!-- Sélecteur GPO + bouton Ajouter -->
                        <Border Grid.Row="0"
                                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,6">
                            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,10,Auto">
                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Text="{Binding Source={StaticResource Loc}, Path=RelationsLabelGpo}"
                                           FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <ComboBox Grid.Row="1" Grid.Column="0"
                                          SelectedItem="{Binding GpoLinkGpoObject, Mode=TwoWay}"
                                          ItemsSource="{Binding AvailableGPOs}"
                                          PlaceholderText="{Binding Source={StaticResource Loc}, Path=RelationsChooseGPO}"
                                          HorizontalAlignment="Stretch">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ADObjectSuggestion">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Classes="EmojiIcon" Text="{Binding Icon}" FontSize="14" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <Button Grid.Row="1" Grid.Column="2"
                                        Content="{Binding Source={StaticResource Loc}, Path=RelationsAdd}"
                                        Command="{Binding #RelationsWindowRoot.DataContext.AddGpoLinkCommand}"
                                        Padding="12,6" Background="#107C10" Foreground="White" VerticalAlignment="Bottom"/>
                            </Grid>
                        </Border>

                        <!-- En-têtes liste -->
                        <Grid Grid.Row="1" ColumnDefinitions="180,*">
                            <Border Grid.Column="0" Classes="RelHeader"><TextBlock Text="{Binding Source={StaticResource Loc}, Path=RelationsColTargetOU}" FontWeight="SemiBold"/></Border>
                            <Border Grid.Column="1" Classes="RelHeader"><TextBlock Text="{Binding Source={StaticResource Loc}, Path=RelationsColGpo}" FontWeight="SemiBold"/></Border>
                        </Grid>

                        <!-- Liste des liens existants -->
                        <ListBox Grid.Row="2" ItemsSource="{Binding GpoLinks}" SelectedItem="{Binding SelectedGpoLink, Mode=TwoWay}">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:RelationEntry">
                                    <Grid ColumnDefinitions="180,*">
                                        <Border Grid.Column="0" Classes="RelRow"><TextBlock Text="{Binding Source}" TextTrimming="CharacterEllipsis"/></Border>
                                        <Border Grid.Column="1" Classes="RelRow"><TextBlock Text="{Binding Target}" TextTrimming="CharacterEllipsis"/></Border>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
                            <Button Classes="BtnDelete"
                                    Content="{Binding Source={StaticResource Loc}, Path=RelationsDelete}"
                                    Command="{Binding #RelationsWindowRoot.DataContext.RemoveGpoLinkCommand}"
                                    Padding="10,5"/>
                        </StackPanel>
                    </Grid>

                </Grid>
            </TabItem>

            <!-- ===== ONGLET PSO ===== -->
            <TabItem Header="{Binding Source={StaticResource Loc}, Path=RelationsTabPsoLinks}">
                <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="8">

                    <Border Grid.Row="0" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                            BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,6">
                        <Grid ColumnDefinitions="*,30,*,10,Auto" RowDefinitions="Auto,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="{Binding Source={StaticResource Loc}, Path=RelationsLabelPso}"
                                       FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="2"
                                       Text="{Binding Source={StaticResource Loc}, Path=RelationsLabelTargetPso}"
                                       FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <ComboBox Grid.Row="1" Grid.Column="0"
                                      SelectedItem="{Binding PsoLinkPsoObject, Mode=TwoWay}"
                                      ItemsSource="{Binding AvailablePSOs}"
                                      PlaceholderText="{Binding Source={StaticResource Loc}, Path=RelationsChoosePSO}"
                                      HorizontalAlignment="Stretch">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ADObjectSuggestion">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Classes="EmojiIcon" Text="{Binding Icon}" FontSize="14" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="→" FontSize="18"
                                       VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#CA5010"/>
                            <ComboBox Grid.Row="1" Grid.Column="2"
                                      SelectedItem="{Binding PsoLinkTargetObject, Mode=TwoWay}"
                                      ItemsSource="{Binding AvailableMembershipTargets}"
                                      PlaceholderText="{Binding Source={StaticResource Loc}, Path=RelationsChooseTarget}"
                                      HorizontalAlignment="Stretch">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ADObjectSuggestion">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Classes="EmojiIcon" Text="{Binding Icon}" FontSize="14" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <Button Grid.Row="1" Grid.Column="4"
                                    Content="{Binding Source={StaticResource Loc}, Path=RelationsAdd}"
                                    Command="{Binding #RelationsWindowRoot.DataContext.AddPsoLinkCommand}"
                                    Padding="12,6" Background="#CA5010" Foreground="White" VerticalAlignment="Bottom"/>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" ColumnDefinitions="220,*">
                        <Border Grid.Column="0" Classes="RelHeader"><TextBlock Text="{Binding Source={StaticResource Loc}, Path=RelationsColPso}" FontWeight="SemiBold"/></Border>
                        <Border Grid.Column="1" Classes="RelHeader"><TextBlock Text="{Binding Source={StaticResource Loc}, Path=RelationsColTargetPso}" FontWeight="SemiBold"/></Border>
                    </Grid>

                    <ListBox Grid.Row="2" ItemsSource="{Binding PsoLinks}" SelectedItem="{Binding SelectedPsoLink, Mode=TwoWay}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:RelationEntry">
                                <Grid ColumnDefinitions="220,*">
                                    <Border Grid.Column="0" Classes="RelRow"><TextBlock Text="{Binding Source}" TextTrimming="CharacterEllipsis"/></Border>
                                    <Border Grid.Column="1" Classes="RelRow"><TextBlock Text="{Binding Target}" TextTrimming="CharacterEllipsis"/></Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
                        <Button Classes="BtnDelete"
                                Content="{Binding Source={StaticResource Loc}, Path=RelationsDelete}"
                                Command="{Binding #RelationsWindowRoot.DataContext.RemovePsoLinkCommand}"
                                Padding="10,5"/>
                    </StackPanel>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- Barre de statut + bouton Fermer -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="10,0,10,10">
            <Border Grid.Column="0" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                    CornerRadius="4" Padding="8,4">
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" FontSize="12"
                           Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
            </Border>
            <Button Grid.Column="1"
                    Content="{Binding Source={StaticResource Loc}, Path=RelationsClose}"
                    Click="OnCloseClick"
                    Padding="16,6" Margin="10,0,0,0" Background="#0078D4" Foreground="White"/>
        </Grid>
    </Grid>
</Window>
