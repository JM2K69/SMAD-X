<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SMADX.ViewModels"
        xmlns:services="using:SMADX.Services"
        xmlns:helpers="using:SMADX.Helpers"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="800"
        x:Class="SMADX.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:Name="MainWindowRoot"
        Icon="/Assets/icone.ico"
        Title="SMAD-X"
        Width="1400" Height="855">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <!-- Bindings MVVM pour TreeViewItem — les couleurs sont dans AppStyles.axaml -->
        <Style Selector="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
            <Setter Property="IsVisible" Value="{Binding IsVisible}"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Menu et Toolbar -->
        <Grid Grid.Row="0" RowDefinitions="Auto,Auto">
            <!-- Menu principal -->
            <Menu Grid.Row="0" x:Name="MainMenu" DataContext="{StaticResource Loc}">
                <MenuItem Header="{Binding MenuFile}">
                    <MenuItem Header="{Binding MenuFileNewDomain}" Command="{Binding #MainWindowRoot.DataContext.CreateNewDomainCommand}" InputGesture="Ctrl+N"/>
                    <MenuItem Header="{Binding MenuFileNewStructure}" Command="{Binding #MainWindowRoot.DataContext.InitializeSampleDataCommand}" InputGesture="Ctrl+Shift+N"/>
                    <Separator/>
                    <MenuItem Header="{Binding MenuFileOpen}" Command="{Binding #MainWindowRoot.DataContext.LoadFromFileCommand}" InputGesture="Ctrl+O"/>
                    <MenuItem Header="{Binding MenuFileSave}" Command="{Binding #MainWindowRoot.DataContext.SaveToFileCommand}" InputGesture="Ctrl+S"/>
                    <Separator/>
                    <MenuItem Header="{Binding MenuFileExportJson}" Command="{Binding #MainWindowRoot.DataContext.ExportToJsonCommand}" InputGesture="Ctrl+E"/>
                    <MenuItem Header="{Binding MenuFileExportPowerShell}" Command="{Binding #MainWindowRoot.DataContext.ExportToPowerShellCommand}" InputGesture="Ctrl+P"/>
                    <MenuItem Header="{Binding MenuFileGenerateImportScript}" Command="{Binding #MainWindowRoot.DataContext.GenerateImportScriptCommand}" InputGesture="Ctrl+I"/>
                    <Separator/>
                    <MenuItem Header="{Binding MenuFileExit}" Click="OnExitClick" InputGesture="Alt+F4"/>
                </MenuItem>
                <MenuItem Header="{Binding MenuEdit}">
                    <MenuItem Header="{Binding MenuEditCopy}" Command="{Binding #MainWindowRoot.DataContext.CopyObjectCommand}" InputGesture="Ctrl+C"/>
                    <MenuItem Header="{Binding MenuEditPaste}" Command="{Binding #MainWindowRoot.DataContext.PasteObjectCommand}" InputGesture="Ctrl+V"/>
                    <Separator/>
                    <MenuItem Header="{Binding MenuEditRename}" Command="{Binding #MainWindowRoot.DataContext.RenameObjectCommand}" InputGesture="F2"/>
                    <MenuItem Header="{Binding MenuEditDelete}" Command="{Binding #MainWindowRoot.DataContext.DeleteObjectCommand}" InputGesture="Delete"/>
                    <Separator/>
                    <MenuItem Header="{Binding MenuEditAddPSO}" Command="{Binding #MainWindowRoot.DataContext.AddPasswordSettingsObjectCommand}"/>
                </MenuItem>
                <MenuItem Header="{Binding MenuView}">
                        <MenuItem Header="{Binding MenuViewExpandAll}" Command="{Binding #MainWindowRoot.DataContext.ExpandAllCommand}"/>
                        <MenuItem Header="{Binding MenuViewCollapseAll}" Command="{Binding #MainWindowRoot.DataContext.CollapseAllCommand}"/>
                        <Separator/>
                        <MenuItem Command="{Binding #MainWindowRoot.DataContext.ManageRelationsCommand}">
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="🔗" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding MenuViewManageRelations}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </MenuItem.Header>
                        </MenuItem>
                        <MenuItem Header="{Binding MenuViewShowGraph}" Command="{Binding #MainWindowRoot.DataContext.ShowGraphViewCommand}"/>
                        <Separator/>
                        <MenuItem Header="{Binding MenuViewTheme}">
                            <MenuItem Header="{Binding MenuViewThemeLight}" Click="OnLightThemeClick"/>
                            <MenuItem Header="{Binding MenuViewThemeDark}" Click="OnDarkThemeClick"/>
                        </MenuItem>
                        <MenuItem Header="{Binding MenuViewLanguage}">
                            <MenuItem Header="{Binding MenuViewLanguageFrench}" Click="OnFrenchLanguageClick"/>
                            <MenuItem Header="{Binding MenuViewLanguageEnglish}" Click="OnEnglishLanguageClick"/>
                        </MenuItem>
                    </MenuItem>
                <MenuItem Header="{Binding MenuSettings}">
                    <MenuItem Header="{Binding MenuSettingsManageTiers}" Click="OnTierConfigClick"/>
                </MenuItem>
                <MenuItem Header="{Binding MenuHelp}">
                    <MenuItem Header="{Binding MenuHelpAbout}" Click="OnAboutClick"/>
                </MenuItem>
            </Menu>

            <!-- Toolbar -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5" Spacing="5" x:Name="Toolbar" DataContext="{StaticResource Loc}">
                <Button Command="{Binding #MainWindowRoot.DataContext.AddOrganizationalUnitCommand}" Padding="10,5">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="📁" FontSize="14"/>
                        <TextBlock Text="{Binding ToolbarOU}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding #MainWindowRoot.DataContext.AddContainerCommand}" Padding="10,5">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="📦" FontSize="14"/>
                        <TextBlock Text="{Binding ToolbarContainer}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding #MainWindowRoot.DataContext.AddUserCommand}" Padding="10,5">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="👤" FontSize="14"/>
                        <TextBlock Text="{Binding ToolbarUser}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding #MainWindowRoot.DataContext.AddGroupCommand}" Padding="10,5">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="👥" FontSize="14"/>
                        <TextBlock Text="{Binding ToolbarGroup}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding #MainWindowRoot.DataContext.AddComputerCommand}" Padding="10,5">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="💻" FontSize="14"/>
                        <TextBlock Text="{Binding ToolbarComputer}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding #MainWindowRoot.DataContext.AddGMSACommand}" Padding="10,5">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="🔐" FontSize="14"/>
                        <TextBlock Text="{Binding ToolbarGMSA}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding #MainWindowRoot.DataContext.AddPolicyCommand}" Padding="10,5">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="📋" FontSize="14"/>
                        <TextBlock Text="{Binding ToolbarPolicy}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding #MainWindowRoot.DataContext.AddPasswordSettingsObjectCommand}" Padding="10,5">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="🔑" FontSize="14"/>
                        <TextBlock Text="{Binding ToolbarPSO}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Separator Width="1" Height="30"/>
                <Button Command="{Binding #MainWindowRoot.DataContext.DeleteObjectCommand}" Padding="10,5">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="🗑️" FontSize="14"/>
                        <TextBlock Text="{Binding ToolbarDelete}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Separator Width="1" Height="30"/>
                <Button Command="{Binding #MainWindowRoot.DataContext.ManageRelationsCommand}"
                        Classes="BtnRelations"
                        Padding="10,5"
                        Background="{DynamicResource AppRelationsBtnBgBrush}"
                        Foreground="{DynamicResource AppRelationsBtnFgBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="🔗" FontSize="14"/>
                        <TextBlock Text="{Binding ToolbarRelations}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding #MainWindowRoot.DataContext.ShowGraphViewCommand}"
                        Classes="BtnGraph"
                        Padding="10,5"
                        Background="{DynamicResource AppGraphBtnBgBrush}"
                        Foreground="{DynamicResource AppGraphBtnFgBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="🕸️" FontSize="14"/>
                        <TextBlock Text="{Binding ToolbarGraph}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Separator Width="1" Height="30"/>
                <Button Click="OnExportTreePngClick" Padding="10,5" Background="#1E5631">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="📷" FontSize="14"/>
                        <TextBlock Text="Export PNG" VerticalAlignment="Center" Foreground="White"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Zone principale : TreeView + Détails -->
        <Grid Grid.Row="1" ColumnDefinitions="400,5,*">
            <!-- TreeView -->
            <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Padding="5">
                <Grid RowDefinitions="Auto,Auto,*" DataContext="{StaticResource Loc}">
                    <TextBlock Grid.Row="0" Text="{Binding TreeViewTitle}" 
                               FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>

                    <!-- ═══ BARRE DE RECHERCHE ═══ -->
                    <Border Grid.Row="1" Margin="0,0,0,8" CornerRadius="4"
                            BorderThickness="1" BorderBrush="{DynamicResource AppSeparatorBrush}">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <TextBlock Grid.Column="0" Text="🔍" FontSize="13"
                                       FontFamily="Segoe UI Emoji"
                                       VerticalAlignment="Center" Margin="8,0,4,0"
                                       Foreground="{DynamicResource AppTreeFgBrush}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding #MainWindowRoot.DataContext.SearchText, Mode=TwoWay}"
                                     PlaceholderText="{Binding SearchPlaceholder}"
                                     BorderThickness="0" Background="Transparent"
                                     Padding="2,6" FontSize="13"
                                     VerticalAlignment="Center"/>
                            <Button Grid.Column="2"
                                    Content="✕"
                                    Command="{Binding #MainWindowRoot.DataContext.ClearSearchCommand}"
                                    IsVisible="{Binding #MainWindowRoot.DataContext.SearchText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="6,4" FontSize="11"
                                    Foreground="{DynamicResource AppTreeFgBrush}"
                                    ToolTip.Tip="Effacer la recherche"/>
                        </Grid>
                    </Border>

                    <TreeView Grid.Row="2"
                              x:Name="MainTreeView"
                              ItemsSource="{Binding #MainWindowRoot.DataContext.RootNodes}"
                              SelectedItem="{Binding #MainWindowRoot.DataContext.SelectedNode, Mode=TwoWay}">
                        <TreeView.ContextMenu>
                            <ContextMenu>
                                <!-- Ajouter OU -->
                                <MenuItem Header="{Binding Source={StaticResource Loc}, Path=ContextMenuAddOU}"
                                          Command="{Binding #MainWindowRoot.DataContext.AddOrganizationalUnitCommand}"
                                          IsVisible="{Binding #MainWindowRoot.DataContext.CanAddOU}">
                                    <MenuItem.Icon><TextBlock Text="📁" FontSize="14" FontFamily="Segoe UI Emoji"/></MenuItem.Icon>
                                </MenuItem>
                                <!-- Ajouter Container -->
                                <MenuItem Header="{Binding Source={StaticResource Loc}, Path=ContextMenuAddContainer}"
                                          Command="{Binding #MainWindowRoot.DataContext.AddContainerCommand}"
                                          IsVisible="{Binding #MainWindowRoot.DataContext.CanAddContainer}">
                                    <MenuItem.Icon><TextBlock Text="📦" FontSize="14" FontFamily="Segoe UI Emoji"/></MenuItem.Icon>
                                </MenuItem>
                                <!-- Ajouter Utilisateur -->
                                <MenuItem Header="{Binding Source={StaticResource Loc}, Path=ContextMenuAddUser}"
                                          Command="{Binding #MainWindowRoot.DataContext.AddUserCommand}"
                                          IsVisible="{Binding #MainWindowRoot.DataContext.CanAddUser}">
                                    <MenuItem.Icon><TextBlock Text="👤" FontSize="14" FontFamily="Segoe UI Emoji"/></MenuItem.Icon>
                                </MenuItem>
                                <!-- Ajouter Groupe -->
                                <MenuItem Header="{Binding Source={StaticResource Loc}, Path=ContextMenuAddGroup}"
                                          Command="{Binding #MainWindowRoot.DataContext.AddGroupCommand}"
                                          IsVisible="{Binding #MainWindowRoot.DataContext.CanAddGroup}">
                                    <MenuItem.Icon><TextBlock Text="👥" FontSize="14" FontFamily="Segoe UI Emoji"/></MenuItem.Icon>
                                </MenuItem>
                                <!-- Ajouter Ordinateur -->
                                <MenuItem Header="{Binding Source={StaticResource Loc}, Path=ContextMenuAddComputer}"
                                          Command="{Binding #MainWindowRoot.DataContext.AddComputerCommand}"
                                          IsVisible="{Binding #MainWindowRoot.DataContext.CanAddComputer}">
                                    <MenuItem.Icon><TextBlock Text="💻" FontSize="14" FontFamily="Segoe UI Emoji"/></MenuItem.Icon>
                                </MenuItem>
                                <!-- Ajouter GMSA -->
                                <MenuItem Header="{Binding Source={StaticResource Loc}, Path=ContextMenuAddGMSA}"
                                          Command="{Binding #MainWindowRoot.DataContext.AddGMSACommand}"
                                          IsVisible="{Binding #MainWindowRoot.DataContext.CanAddGMSA}">
                                    <MenuItem.Icon><TextBlock Text="🔐" FontSize="14" FontFamily="Segoe UI Emoji"/></MenuItem.Icon>
                                </MenuItem>
                                <!-- Ajouter GPO -->
                                <MenuItem Header="{Binding Source={StaticResource Loc}, Path=ContextMenuAddPolicy}"
                                          Command="{Binding #MainWindowRoot.DataContext.AddPolicyCommand}"
                                          IsVisible="{Binding #MainWindowRoot.DataContext.CanAddPolicy}">
                                    <MenuItem.Icon><TextBlock Text="📋" FontSize="14" FontFamily="Segoe UI Emoji"/></MenuItem.Icon>
                                </MenuItem>
                                <!-- Ajouter PSO -->
                                <MenuItem Header="{Binding Source={StaticResource Loc}, Path=ContextMenuAddPSO}"
                                          Command="{Binding #MainWindowRoot.DataContext.AddPasswordSettingsObjectCommand}"
                                          IsVisible="{Binding #MainWindowRoot.DataContext.CanAddPSO}">
                                    <MenuItem.Icon><TextBlock Text="🔑" FontSize="14" FontFamily="Segoe UI Emoji"/></MenuItem.Icon>
                                </MenuItem>
                                <!-- Séparateur entre ajout enfant et actions objet -->
                                <Separator IsVisible="{Binding #MainWindowRoot.DataContext.CanAddAnyChild}"/>
                                <!-- Ajouter au groupe (User / Computer / GMSA) -->
                                <MenuItem Header="{Binding Source={StaticResource Loc}, Path=ContextMenuAddToGroup}"
                                          Command="{Binding #MainWindowRoot.DataContext.AddToGroupCommand}"
                                          IsVisible="{Binding #MainWindowRoot.DataContext.CanAddToGroup}">
                                    <MenuItem.Icon><TextBlock Text="👥" FontSize="14" FontFamily="Segoe UI Emoji"/></MenuItem.Icon>
                                </MenuItem>
                                <!-- Ajouter des membres (Group) -->
                                <MenuItem Header="{Binding Source={StaticResource Loc}, Path=ContextMenuAddMember}"
                                          Command="{Binding #MainWindowRoot.DataContext.AddMemberCommand}"
                                          IsVisible="{Binding #MainWindowRoot.DataContext.CanAddMember}">
                                    <MenuItem.Icon><TextBlock Text="👤" FontSize="14" FontFamily="Segoe UI Emoji"/></MenuItem.Icon>
                                </MenuItem>
                                <!-- Imbrication groupe dans groupe -->
                                <MenuItem Header="{Binding Source={StaticResource Loc}, Path=ContextMenuAddGroupToGroup}"
                                          Command="{Binding #MainWindowRoot.DataContext.AddGroupToGroupCommand}"
                                          IsVisible="{Binding #MainWindowRoot.DataContext.CanAddGroupToGroup}">
                                    <MenuItem.Icon><TextBlock Text="👥" FontSize="14" FontFamily="Segoe UI Emoji"/></MenuItem.Icon>
                                </MenuItem>
                                <!-- Séparateur avant édition -->
                                <Separator IsVisible="{Binding #MainWindowRoot.DataContext.CanAddToGroup}"/>
                                <Separator IsVisible="{Binding #MainWindowRoot.DataContext.CanAddMember}"/>
                                <!-- Renommer -->
                                <MenuItem Header="{Binding Source={StaticResource Loc}, Path=ContextMenuRename}"
                                          Command="{Binding #MainWindowRoot.DataContext.RenameObjectCommand}"
                                          IsEnabled="{Binding #MainWindowRoot.DataContext.CanCopySelected}">
                                    <MenuItem.Icon><TextBlock Text="✏️" FontSize="14" FontFamily="Segoe UI Emoji"/></MenuItem.Icon>
                                </MenuItem>
                                <!-- Copier -->
                                <MenuItem Header="{Binding Source={StaticResource Loc}, Path=ContextMenuCopy}"
                                          Command="{Binding #MainWindowRoot.DataContext.CopyObjectCommand}"
                                          IsEnabled="{Binding #MainWindowRoot.DataContext.CanCopySelected}">
                                    <MenuItem.Icon><TextBlock Text="📋" FontSize="14" FontFamily="Segoe UI Emoji"/></MenuItem.Icon>
                                </MenuItem>
                                <!-- Coller -->
                                <MenuItem Header="{Binding Source={StaticResource Loc}, Path=ContextMenuPaste}"
                                          Command="{Binding #MainWindowRoot.DataContext.PasteObjectCommand}"
                                          IsEnabled="{Binding #MainWindowRoot.DataContext.CanCopySelected}">
                                    <MenuItem.Icon><TextBlock Text="📌" FontSize="14" FontFamily="Segoe UI Emoji"/></MenuItem.Icon>
                                </MenuItem>
                                <Separator/>
                                <!-- Supprimer -->
                                <MenuItem Header="{Binding Source={StaticResource Loc}, Path=ContextMenuDelete}"
                                          Command="{Binding #MainWindowRoot.DataContext.DeleteObjectCommand}"
                                          IsEnabled="{Binding #MainWindowRoot.DataContext.CanDeleteSelected}">
                                    <MenuItem.Icon><TextBlock Text="🗑️" FontSize="14" FontFamily="Segoe UI Emoji"/></MenuItem.Icon>
                                </MenuItem>
                                <Separator/>
                                <!-- Gérer les relations -->
                                <MenuItem Header="{Binding Source={StaticResource Loc}, Path=ContextMenuManageRelations}"
                                          Command="{Binding #MainWindowRoot.DataContext.ManageRelationsCommand}"
                                          IsEnabled="{Binding #MainWindowRoot.DataContext.CanManageRelations}">
                                    <MenuItem.Icon><TextBlock Text="🔗" FontSize="14" FontFamily="Segoe UI Emoji"/></MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </TreeView.ContextMenu>
                        <TreeView.ItemTemplate>
                            <TreeDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <TextBlock Text="{Binding Icon}" FontSize="16" FontFamily="Segoe UI Emoji,Apple Color Emoji,Noto Color Emoji"/>
                                    <TextBlock Text="{Binding Data.Name}" VerticalAlignment="Center"/>
                                    <Border IsVisible="{Binding Data.Tier, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                            Background="#22000000" CornerRadius="3" Padding="4,1"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Data.Tier}"
                                                   Foreground="{Binding TierColor}"
                                                   FontSize="10" FontWeight="SemiBold"/>
                                    </Border>
                                    <!-- Badge GPO lié -->
                                    <Border IsVisible="{Binding HasLinkedGPOs}"
                                            Background="#1A6B2F" CornerRadius="3" Padding="4,1"
                                            VerticalAlignment="Center"
                                            ToolTip.Tip="{Binding LinkedGPOsSummary}">
                                        <TextBlock Text="🔗 GPO"
                                                   Foreground="#7FFF9A"
                                                   FontSize="9" FontWeight="SemiBold"/>
                                    </Border>
                                </StackPanel>
                            </TreeDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>
            </Border>

            <!-- Séparateur -->
            <GridSplitter Grid.Column="1" Background="LightGray" ResizeDirection="Columns"/>

            <!-- Panneau de détails -->
            <Border Grid.Column="2" BorderBrush="Gray" BorderThickness="1" Padding="10">
                <ScrollViewer>
                    <Grid RowDefinitions="Auto,*" DataContext="{StaticResource Loc}">
                        <!-- Titre du panneau de détails avec binding -->
                        <TextBlock Grid.Row="0" 
                                   Text="{Binding DetailsTitle}" 
                                   FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>

                        <StackPanel Grid.Row="1" Spacing="10">
                            <StackPanel Spacing="5">
                                <TextBlock Text="{Binding DetailsName}" FontWeight="SemiBold"/>
                                <TextBox Text="{Binding #MainWindowRoot.DataContext.SelectedObjectName, Mode=TwoWay}"
                                     helpers:FocusExtensions.IsFocused="{Binding #MainWindowRoot.DataContext.SelectedNode.IsEditing, Mode=TwoWay}" />
                            </StackPanel>

                            <StackPanel Spacing="5">
                                <TextBlock Text="{Binding DetailsType}" FontWeight="SemiBold"/>
                                <TextBox Text="{Binding #MainWindowRoot.DataContext.SelectedObjectType}" IsReadOnly="True"/>
                            </StackPanel>

                            <StackPanel Spacing="5">
                                <TextBlock Text="{Binding DetailsDN}" FontWeight="SemiBold"/>
                                <TextBox Text="{Binding #MainWindowRoot.DataContext.SelectedObjectDistinguishedName}" 
                                         IsReadOnly="True" TextWrapping="Wrap"/>
                            </StackPanel>

                            <StackPanel Spacing="5">
                                <TextBlock Text="{Binding DetailsTier}" FontWeight="SemiBold"/>
                                <ComboBox x:Name="TierComboBox"
                                          SelectedIndex="{Binding #MainWindowRoot.DataContext.SelectedObjectTierIndex, Mode=OneWay}"
                                          ItemsSource="{Binding #MainWindowRoot.DataContext.AvailableTiers}"
                                          SelectionChanged="OnTierComboBoxSelectionChanged"
                                          Width="200" HorizontalAlignment="Left"/>
                            </StackPanel>

                                            <Separator/>

                                            <StackPanel Spacing="5">
                                                <DockPanel>
                                                    <TextBlock Text="{Binding DetailsDescription}" FontWeight="SemiBold" 
                                                               DockPanel.Dock="Left"/>
                                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="5">
                                                        <Button Command="{Binding #MainWindowRoot.DataContext.ToggleMarkdownEditCommand}"
                                                                HorizontalAlignment="Right"
                                                                Padding="8,4">
                                                            <StackPanel Orientation="Horizontal" Spacing="3">
                                                                <TextBlock Text="{Binding #MainWindowRoot.DataContext.IsMarkdownEditMode}" IsVisible="False"/>
                                                                <TextBlock Text="{Binding DetailsEdit}" IsVisible="{Binding !#MainWindowRoot.DataContext.IsMarkdownEditMode}"/>
                                                                <TextBlock Text="{Binding DetailsPreview}" IsVisible="{Binding #MainWindowRoot.DataContext.IsMarkdownEditMode}"/>
                                                            </StackPanel>
                                                        </Button>
                                                    </StackPanel>
                                                </DockPanel>

                                                <TextBox Text="{Binding #MainWindowRoot.DataContext.SelectedObjectDescription, Mode=TwoWay}" 
                                                         AcceptsReturn="True" 
                                                         TextWrapping="Wrap"
                                                         Height="300"
                                                         IsVisible="{Binding #MainWindowRoot.DataContext.IsMarkdownEditMode}"/>

                                                <Border BorderBrush="LightGray" BorderThickness="1" 
                                                        Padding="10" Height="300"
                                                        IsVisible="{Binding !#MainWindowRoot.DataContext.IsMarkdownEditMode}">
                                                    <ScrollViewer>
                                                        <ContentControl Content="{Binding #MainWindowRoot.DataContext.SelectedObjectDescription, Converter={StaticResource MarkdownConverter}}"/>
                                                    </ScrollViewer>
                                                </Border>
                                            </StackPanel>

                                            <Separator/>

                                            <StackPanel Spacing="5">
                                                <TextBlock Text="{Binding DetailsActions}" FontWeight="SemiBold"/>
                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                    <Button Content="{Binding ActionRename}" Command="{Binding #MainWindowRoot.DataContext.RenameObjectCommand}" Padding="10,5"/>
                                                    <Button Content="{Binding ActionCopy}" Command="{Binding #MainWindowRoot.DataContext.CopyObjectCommand}" Padding="10,5"/>
                                                    <Button Content="{Binding ActionDelete}" Command="{Binding #MainWindowRoot.DataContext.DeleteObjectCommand}" 
                                                            Padding="10,5" Background="#CC0000"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- ===== RELATIONS CONTEXTUELLES ===== -->

                                            <!-- MemberOf : User ou Groupe -->
                                            <StackPanel Spacing="5"
                                                        IsVisible="{Binding #MainWindowRoot.DataContext.SelectedSupportsMemberOf}">
                                                <Separator/>
                                                <DockPanel>
                                                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=DetailsMemberOf}" FontWeight="SemiBold" DockPanel.Dock="Left"/>
                                                    <Button Content="{Binding Source={StaticResource Loc}, Path=ActionManage}" DockPanel.Dock="Right"
                                                            Command="{Binding #MainWindowRoot.DataContext.ManageRelationsCommand}"
                                                            Padding="8,3" FontSize="11"/>
                                                </DockPanel>
                                                <ScrollViewer MaxHeight="150" VerticalScrollBarVisibility="Auto">
                                                    <ItemsControl ItemsSource="{Binding #MainWindowRoot.DataContext.SelectedMemberOf}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Background="{DynamicResource AppSelectedItemBrush}" CornerRadius="3" Padding="6,3" Margin="0,2">
                                                                    <TextBlock Text="{Binding}" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </ScrollViewer>
                                            </StackPanel>

                                            <!-- LinkedGPOs : OU -->
                                            <StackPanel Spacing="5"
                                                        IsVisible="{Binding #MainWindowRoot.DataContext.SelectedSupportsGpoLinks}">
                                                <Separator/>
                                                <DockPanel>
                                                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=DetailsLinkedGPOs}" FontWeight="SemiBold" DockPanel.Dock="Left"/>
                                                    <Button Content="{Binding Source={StaticResource Loc}, Path=ActionManage}" DockPanel.Dock="Right"
                                                            Command="{Binding #MainWindowRoot.DataContext.ManageRelationsCommand}"
                                                            Padding="8,3" FontSize="11"/>
                                                </DockPanel>
                                                <ScrollViewer MaxHeight="150" VerticalScrollBarVisibility="Auto">
                                                    <ItemsControl ItemsSource="{Binding #MainWindowRoot.DataContext.SelectedLinkedGPOs}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Background="{DynamicResource AppSelectedItemBrush}" CornerRadius="3" Padding="6,3" Margin="0,2">
                                                                    <TextBlock Text="{Binding}" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </ScrollViewer>
                                            </StackPanel>

                                            <!-- PSO subjects -->
                                            <StackPanel Spacing="5"
                                                        IsVisible="{Binding #MainWindowRoot.DataContext.SelectedIsPso}">
                                                <Separator/>
                                                <DockPanel>
                                                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=DetailsPSOAppliesTo}" FontWeight="SemiBold" DockPanel.Dock="Left"/>
                                                    <Button Content="{Binding Source={StaticResource Loc}, Path=ActionManage}" DockPanel.Dock="Right"
                                                            Command="{Binding #MainWindowRoot.DataContext.ManageRelationsCommand}"
                                                            Padding="8,3" FontSize="11"/>
                                                </DockPanel>
                                                <ScrollViewer MaxHeight="150" VerticalScrollBarVisibility="Auto">
                                                    <ItemsControl ItemsSource="{Binding #MainWindowRoot.DataContext.SelectedPSOAppliesTo}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Background="{DynamicResource AppSelectedItemBrush}" CornerRadius="3" Padding="6,3" Margin="0,2">
                                                                    <TextBlock Text="{Binding}" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </ScrollViewer>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </ScrollViewer>
                            </Border>
                        </Grid>

        <!-- Barre d'état -->
        <Grid Grid.Row="2" Height="30" ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" 
                       VerticalAlignment="Center" Margin="10,0"/>
            <TextBlock Grid.Column="1" Text="{Binding ObjectCountsSummary}" 
                       VerticalAlignment="Center" Margin="10,0" FontSize="11"/>
        </Grid>
    </Grid>
</Window>
