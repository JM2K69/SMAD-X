<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="500"
        x:Class="SMADX.Views.AboutDialog"
        Title="{Binding Source={StaticResource Loc}, Path=AboutTitle}"
        Icon="/Assets/icone.ico"
        Width="650" Height="550"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <Grid Margin="20" RowDefinitions="Auto,Auto,Auto,*,Auto,Auto" DataContext="{StaticResource Loc}">

        <!-- App Name -->
        <TextBlock Grid.Row="0" 
                   Text="{Binding AboutAppName}" 
                   FontSize="32" 
                   FontWeight="Bold" 
                   HorizontalAlignment="Center"
                   Margin="0,0,0,10"/>

        <!-- Full Name -->
        <TextBlock Grid.Row="1" 
                   Text="{Binding AboutFullName}" 
                   FontSize="16" 
                   FontStyle="Italic"
                   HorizontalAlignment="Center"
                   Foreground="#666666"
                   Margin="0,0,0,5"/>

        <!-- Version -->
        <TextBlock Grid.Row="2" 
                   Text="{Binding AboutVersion}" 
                   FontSize="12" 
                   HorizontalAlignment="Center"
                   Foreground="#888888"
                   Margin="0,0,0,20"/>

        <!-- Description and Features -->
        <ScrollViewer Grid.Row="3" Margin="0,0,0,20">
            <StackPanel Spacing="15">
                <!-- Description -->
                <TextBlock Text="{Binding AboutDescription}" 
                           TextWrapping="Wrap" 
                           FontSize="14"
                           LineHeight="20"/>

                <Separator/>

                <!-- Features Title -->
                <TextBlock Text="{Binding AboutFeatures}" 
                           FontWeight="Bold" 
                           FontSize="14"/>

                <!-- Features List -->
                <StackPanel Spacing="8">
                    <TextBlock Text="{Binding AboutFeature1}" FontSize="13" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding AboutFeature2}" FontSize="13" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding AboutFeature3}" FontSize="13" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding AboutFeature4}" FontSize="13" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding AboutFeature5}" FontSize="13" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding AboutFeature6}" FontSize="13" TextWrapping="Wrap"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Copyright -->
        <TextBlock Grid.Row="4" 
                   Text="{Binding AboutCopyright}" 
                   FontSize="11" 
                   HorizontalAlignment="Center"
                   Foreground="#888888"
                   Margin="0,10,0,15"/>

        <!-- Close Button -->
        <Button Grid.Row="5" 
                Content="{Binding AboutClose}" 
                HorizontalAlignment="Center"
                Width="120"
                Padding="15,8"
                Click="OnCloseClick"/>
    </Grid>
</Window>
