<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SMADX.ViewModels"
        xmlns:services="using:SMADX.Services"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="800"
        x:Class="SMADX.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:Name="MainWindowRoot"
        Icon="/Assets/avalonia-logo.ico"
        Title="Active Directory Simulator"
        Width="1400" Height="855">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
        </Style>
        <!-- Force le foreground des boutons toolbar (normal + survol) pour éviter la pollution visuelle après GraphWindow -->
        <Style Selector="#Toolbar Button">
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
        </Style>
        <Style Selector="#Toolbar Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
        </Style>
        <!-- Corrige la bande blanche en haut du popup de menu en thème sombre -->
        <Style Selector="MenuFlyoutPresenter">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="Popup > Border">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Menu et Toolbar -->
        <Grid Grid.Row="0" RowDefinitions="Auto,Auto">
            <!-- Menu principal -->
            <Menu Grid.Row="0" x:Name="MainMenu" DataContext="{StaticResource Loc}">
                <MenuItem Header="{Binding MenuFile}">
                    <MenuItem Header="{Binding MenuFileNewDomain}" Command="{Binding #MainWindowRoot.DataContext.CreateNewDomainCommand}" InputGesture="Ctrl+N"/>
                    <MenuItem Header="{Binding MenuFileNewStructure}" Command="{Binding #MainWindowRoot.DataContext.InitializeSampleDataCommand}" InputGesture="Ctrl+Shift+N"/>
                    <Separator/>
                    <MenuItem Header="{Binding MenuFileOpen}" Command="{Binding #MainWindowRoot.DataContext.LoadFromFileCommand}" InputGesture="Ctrl+O"/>
                    <MenuItem Header="{Binding MenuFileSave}" Command="{Binding #MainWindowRoot.DataContext.SaveToFileCommand}" InputGesture="Ctrl+S"/>
                    <Separator/>
                    <MenuItem Header="{Binding MenuFileExportJson}" Command="{Binding #MainWindowRoot.DataContext.ExportToJsonCommand}" InputGesture="Ctrl+E"/>
                    <MenuItem Header="{Binding MenuFileExportPowerShell}" Command="{Binding #MainWindowRoot.DataContext.ExportToPowerShellCommand}" InputGesture="Ctrl+P"/>
                    <MenuItem Header="{Binding MenuFileGenerateImportScript}" Command="{Binding #MainWindowRoot.DataContext.GenerateImportScriptCommand}" InputGesture="Ctrl+I"/>
                    <Separator/>
                    <MenuItem Header="{Binding MenuFileExit}" Click="OnExitClick" InputGesture="Alt+F4"/>
                </MenuItem>
                <MenuItem Header="{Binding MenuEdit}">
                    <MenuItem Header="{Binding MenuEditCopy}" Command="{Binding #MainWindowRoot.DataContext.CopyObjectCommand}" InputGesture="Ctrl+C"/>
                    <MenuItem Header="{Binding MenuEditPaste}" Command="{Binding #MainWindowRoot.DataContext.PasteObjectCommand}" InputGesture="Ctrl+V"/>
                    <Separator/>
                    <MenuItem Header="{Binding MenuEditRename}" Command="{Binding #MainWindowRoot.DataContext.RenameObjectCommand}" InputGesture="F2"/>
                    <MenuItem Header="{Binding MenuEditDelete}" Command="{Binding #MainWindowRoot.DataContext.DeleteObjectCommand}" InputGesture="Delete"/>
                    <Separator/>
                    <MenuItem Header="{Binding MenuEditAddPSO}" Command="{Binding #MainWindowRoot.DataContext.AddPasswordSettingsObjectCommand}"/>
                </MenuItem>
                <MenuItem Header="{Binding MenuView}">
                        <MenuItem Header="{Binding MenuViewExpandAll}" Command="{Binding #MainWindowRoot.DataContext.ExpandAllCommand}"/>
                        <MenuItem Header="{Binding MenuViewCollapseAll}" Command="{Binding #MainWindowRoot.DataContext.CollapseAllCommand}"/>
                        <Separator/>
                        <MenuItem Header="{Binding MenuViewManageRelations}" Command="{Binding #MainWindowRoot.DataContext.ManageRelationsCommand}"/>
                        <MenuItem Header="{Binding MenuViewShowGraph}" Command="{Binding #MainWindowRoot.DataContext.ShowGraphViewCommand}"/>
                        <Separator/>
                        <MenuItem Header="{Binding MenuViewTheme}">
                            <MenuItem Header="{Binding MenuViewThemeLight}" Click="OnLightThemeClick"/>
                            <MenuItem Header="{Binding MenuViewThemeDark}" Click="OnDarkThemeClick"/>
                        </MenuItem>
                        <MenuItem Header="{Binding MenuViewLanguage}">
                            <MenuItem Header="{Binding MenuViewLanguageFrench}" Click="OnFrenchLanguageClick"/>
                            <MenuItem Header="{Binding MenuViewLanguageEnglish}" Click="OnEnglishLanguageClick"/>
                        </MenuItem>
                    </MenuItem>
                <MenuItem Header="{Binding MenuSettings}">
                    <MenuItem Header="{Binding MenuSettingsManageTiers}" Click="OnTierConfigClick"/>
                </MenuItem>
                <MenuItem Header="{Binding MenuHelp}">
                    <MenuItem Header="{Binding MenuHelpAbout}" Click="OnAboutClick"/>
                </MenuItem>
            </Menu>

            <!-- Toolbar -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5" Spacing="5" x:Name="Toolbar" DataContext="{StaticResource Loc}">
                <Button Content="{Binding ToolbarOU, StringFormat='📁 {0}'}" Command="{Binding #MainWindowRoot.DataContext.AddOrganizationalUnitCommand}" 
                        ToolTip.Tip="Ajouter une Unité Organisationnelle" Padding="10,5"/>
                <Button Content="{Binding ToolbarContainer, StringFormat='📦 {0}'}" Command="{Binding #MainWindowRoot.DataContext.AddContainerCommand}" 
                        ToolTip.Tip="Ajouter un Container" Padding="10,5"/>
                <Button Content="{Binding ToolbarUser, StringFormat='👤 {0}'}" Command="{Binding #MainWindowRoot.DataContext.AddUserCommand}" 
                        ToolTip.Tip="Ajouter un Utilisateur" Padding="10,5"/>
                <Button Content="{Binding ToolbarGroup, StringFormat='👥 {0}'}" Command="{Binding #MainWindowRoot.DataContext.AddGroupCommand}" 
                        ToolTip.Tip="Ajouter un Groupe" Padding="10,5"/>
                <Button Content="{Binding ToolbarComputer, StringFormat='💻 {0}'}" Command="{Binding #MainWindowRoot.DataContext.AddComputerCommand}" 
                        ToolTip.Tip="Ajouter un Ordinateur" Padding="10,5"/>
                <Button Content="{Binding ToolbarGMSA, StringFormat='🔐 {0}'}" Command="{Binding #MainWindowRoot.DataContext.AddGMSACommand}" 
                        ToolTip.Tip="Ajouter un GMSA" Padding="10,5"/>
                <Button Content="{Binding ToolbarPolicy, StringFormat='📋 {0}'}" Command="{Binding #MainWindowRoot.DataContext.AddPolicyCommand}" 
                        ToolTip.Tip="Ajouter une Policy" Padding="10,5"/>
                <Button Content="{Binding ToolbarPSO, StringFormat='🔑 {0}'}" Command="{Binding #MainWindowRoot.DataContext.AddPasswordSettingsObjectCommand}" 
                        ToolTip.Tip="Ajouter un Password Settings Object" Padding="10,5"/>
                <Separator Width="1" Height="30"/>
                <Button Content="{Binding ToolbarDelete, StringFormat='🗑️ {0}'}" Command="{Binding #MainWindowRoot.DataContext.DeleteObjectCommand}" 
                        ToolTip.Tip="{Binding ToolbarDelete}" Padding="10,5"/>
                <Separator Width="1" Height="30"/>
                <Button Content="{Binding ToolbarRelations, StringFormat='🔗 {0}'}" Command="{Binding #MainWindowRoot.DataContext.ManageRelationsCommand}"
                        ToolTip.Tip="{Binding ToolbarRelations}" Padding="10,5" Background="#D0E8FF"/>
                <Button Content="{Binding ToolbarGraph, StringFormat='🕸️ {0}'}" Command="{Binding #MainWindowRoot.DataContext.ShowGraphViewCommand}"
                        ToolTip.Tip="{Binding ToolbarGraph}" Padding="10,5" Background="#2D1B4E" Foreground="White"/>
            </StackPanel>
        </Grid>

        <!-- Zone principale : TreeView + Détails -->
        <Grid Grid.Row="1" ColumnDefinitions="400,5,*">
            <!-- TreeView -->
            <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Padding="5">
                <Grid RowDefinitions="Auto,*" DataContext="{StaticResource Loc}">
                    <TextBlock Grid.Row="0" Text="{Binding TreeViewTitle}" 
                               FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                    <TreeView Grid.Row="1" 
                              ItemsSource="{Binding #MainWindowRoot.DataContext.RootNodes}"
                              SelectedItem="{Binding #MainWindowRoot.DataContext.SelectedNode, Mode=TwoWay}">
                        <TreeView.ItemTemplate>
                            <TreeDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <TextBlock Text="{Binding Icon}" FontSize="16"/>
                                    <TextBlock Text="{Binding Data.Name}" VerticalAlignment="Center"/>
                                    <Border IsVisible="{Binding Data.Tier, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                            Background="#22000000" CornerRadius="3" Padding="4,1"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Data.Tier}"
                                                   Foreground="{Binding TierColor}"
                                                   FontSize="10" FontWeight="SemiBold"/>
                                    </Border>
                                </StackPanel>
                            </TreeDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>
            </Border>

            <!-- Séparateur -->
            <GridSplitter Grid.Column="1" Background="LightGray" ResizeDirection="Columns"/>

            <!-- Panneau de détails -->
            <Border Grid.Column="2" BorderBrush="Gray" BorderThickness="1" Padding="10">
                <ScrollViewer>
                    <Grid RowDefinitions="Auto,*" DataContext="{StaticResource Loc}">
                        <!-- Titre du panneau de détails avec binding -->
                        <TextBlock Grid.Row="0" 
                                   Text="{Binding DetailsTitle}" 
                                   FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>

                        <StackPanel Grid.Row="1" Spacing="10">
                            <StackPanel Spacing="5">
                                <TextBlock Text="{Binding DetailsName}" FontWeight="SemiBold"/>
                                <TextBox Text="{Binding #MainWindowRoot.DataContext.SelectedObjectName, Mode=TwoWay}" />
                            </StackPanel>

                            <StackPanel Spacing="5">
                                <TextBlock Text="{Binding DetailsType}" FontWeight="SemiBold"/>
                                <TextBox Text="{Binding #MainWindowRoot.DataContext.SelectedObjectType}" IsReadOnly="True"/>
                            </StackPanel>

                            <StackPanel Spacing="5">
                                <TextBlock Text="{Binding DetailsDN}" FontWeight="SemiBold"/>
                                <TextBox Text="{Binding #MainWindowRoot.DataContext.SelectedObjectDistinguishedName}" 
                                         IsReadOnly="True" TextWrapping="Wrap"/>
                            </StackPanel>

                            <StackPanel Spacing="5">
                                <TextBlock Text="{Binding DetailsTier}" FontWeight="SemiBold"/>
                                <ComboBox SelectedItem="{Binding #MainWindowRoot.DataContext.SelectedObjectTier, Mode=TwoWay}"
                                          ItemsSource="{Binding #MainWindowRoot.DataContext.AvailableTiers}"
                                          Width="200" HorizontalAlignment="Left"/>
                            </StackPanel>

                                            <Separator/>

                                            <StackPanel Spacing="5">
                                                <DockPanel>
                                                    <TextBlock Text="{Binding DetailsDescription}" FontWeight="SemiBold" 
                                                               DockPanel.Dock="Left"/>
                                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="5">
                                                        <Button Command="{Binding #MainWindowRoot.DataContext.ToggleMarkdownEditCommand}"
                                                                HorizontalAlignment="Right"
                                                                Padding="8,4">
                                                            <StackPanel Orientation="Horizontal" Spacing="3">
                                                                <TextBlock Text="{Binding #MainWindowRoot.DataContext.IsMarkdownEditMode}" IsVisible="False"/>
                                                                <TextBlock Text="{Binding DetailsEdit}" IsVisible="{Binding !#MainWindowRoot.DataContext.IsMarkdownEditMode}"/>
                                                                <TextBlock Text="{Binding DetailsPreview}" IsVisible="{Binding #MainWindowRoot.DataContext.IsMarkdownEditMode}"/>
                                                            </StackPanel>
                                                        </Button>
                                                    </StackPanel>
                                                </DockPanel>

                                                <TextBox Text="{Binding #MainWindowRoot.DataContext.SelectedObjectDescription, Mode=TwoWay}" 
                                                         AcceptsReturn="True" 
                                                         TextWrapping="Wrap"
                                                         Height="300"
                                                         IsVisible="{Binding #MainWindowRoot.DataContext.IsMarkdownEditMode}"/>

                                                <Border BorderBrush="LightGray" BorderThickness="1" 
                                                        Padding="10" Height="300"
                                                        IsVisible="{Binding !#MainWindowRoot.DataContext.IsMarkdownEditMode}">
                                                    <ScrollViewer>
                                                        <ContentControl Content="{Binding #MainWindowRoot.DataContext.SelectedObjectDescription, Converter={StaticResource MarkdownConverter}}"/>
                                                    </ScrollViewer>
                                                </Border>
                                            </StackPanel>

                                            <Separator/>

                                            <StackPanel Spacing="5">
                                                <TextBlock Text="{Binding DetailsActions}" FontWeight="SemiBold"/>
                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                    <Button Content="{Binding ActionRename}" Command="{Binding #MainWindowRoot.DataContext.RenameObjectCommand}" Padding="10,5"/>
                                                    <Button Content="{Binding ActionCopy}" Command="{Binding #MainWindowRoot.DataContext.CopyObjectCommand}" Padding="10,5"/>
                                                    <Button Content="{Binding ActionDelete}" Command="{Binding #MainWindowRoot.DataContext.DeleteObjectCommand}" 
                                                            Padding="10,5" Background="#FFDDDD"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- ===== RELATIONS CONTEXTUELLES ===== -->

                                            <!-- MemberOf : User ou Groupe -->
                                            <StackPanel Spacing="5"
                                                        IsVisible="{Binding #MainWindowRoot.DataContext.SelectedSupportsMemberOf}">
                                                <Separator/>
                                                <DockPanel>
                                                    <TextBlock Text="👥 Membre de (groupes)" FontWeight="SemiBold" DockPanel.Dock="Left"/>
                                                    <Button Content="⚙ Gérer" DockPanel.Dock="Right"
                                                            Command="{Binding #MainWindowRoot.DataContext.ManageRelationsCommand}"
                                                            Padding="8,3" FontSize="11"/>
                                                </DockPanel>
                                                <ItemsControl ItemsSource="{Binding #MainWindowRoot.DataContext.SelectedMemberOf}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#EBF3FB" CornerRadius="3" Padding="6,3" Margin="0,2">
                                                                <TextBlock Text="{Binding}" FontSize="12"/>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>

                                            <!-- LinkedGPOs : OU -->
                                            <StackPanel Spacing="5"
                                                        IsVisible="{Binding #MainWindowRoot.DataContext.SelectedSupportsGpoLinks}">
                                                <Separator/>
                                                <DockPanel>
                                                    <TextBlock Text="📋 GPO liées" FontWeight="SemiBold" DockPanel.Dock="Left"/>
                                                    <Button Content="⚙ Gérer" DockPanel.Dock="Right"
                                                            Command="{Binding #MainWindowRoot.DataContext.ManageRelationsCommand}"
                                                            Padding="8,3" FontSize="11"/>
                                                </DockPanel>
                                                <ItemsControl ItemsSource="{Binding #MainWindowRoot.DataContext.SelectedLinkedGPOs}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#EBF6EE" CornerRadius="3" Padding="6,3" Margin="0,2">
                                                                <TextBlock Text="{Binding}" FontSize="12"/>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>

                                            <!-- PSO subjects -->
                                            <StackPanel Spacing="5"
                                                        IsVisible="{Binding #MainWindowRoot.DataContext.SelectedIsPso}">
                                                <Separator/>
                                                <DockPanel>
                                                    <TextBlock Text="🔑 Appliqué à" FontWeight="SemiBold" DockPanel.Dock="Left"/>
                                                    <Button Content="⚙ Gérer" DockPanel.Dock="Right"
                                                            Command="{Binding #MainWindowRoot.DataContext.ManageRelationsCommand}"
                                                            Padding="8,3" FontSize="11"/>
                                                </DockPanel>
                                                <ItemsControl ItemsSource="{Binding #MainWindowRoot.DataContext.SelectedPSOAppliesTo}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#FEF0E6" CornerRadius="3" Padding="6,3" Margin="0,2">
                                                                <TextBlock Text="{Binding}" FontSize="12"/>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </ScrollViewer>
                            </Border>
                        </Grid>

        <!-- Barre d'état -->
        <Grid Grid.Row="2" Height="30" ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" 
                       VerticalAlignment="Center" Margin="10,0"/>
            <TextBlock Grid.Column="1" Text="{Binding ObjectCountsSummary}" 
                       VerticalAlignment="Center" Margin="10,0" FontSize="11"/>
        </Grid>
    </Grid>
</Window>
