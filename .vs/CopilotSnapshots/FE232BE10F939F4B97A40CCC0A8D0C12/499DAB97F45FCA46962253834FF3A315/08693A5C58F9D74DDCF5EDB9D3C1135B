using System;
using System.Collections.Generic;
using System.Linq;
using Avalonia;
using Avalonia.Controls;
using Avalonia.Input;
using Avalonia.Media;
using Avalonia.Threading;
using Activedirectory.Models;

namespace Activedirectory.Graph
{
    /// <summary>
    /// Canvas custom Avalonia — rendu force-directed du graphe AD (style BloodHound)
    /// </summary>
    public class GraphCanvas : Control
    {
        // ── Couleurs par type ──────────────────────────────────────────────
        private static readonly Dictionary<ADObjectType, Color> NodeColors = new()
        {
            { ADObjectType.Domain,                  Color.FromRgb(0x00, 0x78, 0xD4) },
            { ADObjectType.OrganizationalUnit,       Color.FromRgb(0x10, 0x7C, 0x10) },
            { ADObjectType.User,                     Color.FromRgb(0xCA, 0x50, 0x10) },
            { ADObjectType.Group,                    Color.FromRgb(0x88, 0x17, 0x98) },
            { ADObjectType.Computer,                 Color.FromRgb(0x00, 0x4E, 0x8C) },
            { ADObjectType.Policy,                   Color.FromRgb(0xB1, 0x46, 0x00) },
            { ADObjectType.PasswordSettingsObject,   Color.FromRgb(0xC5, 0x07, 0x1F) },
            { ADObjectType.GMSA,                     Color.FromRgb(0x00, 0x64, 0x4D) },
            { ADObjectType.Container,                Color.FromRgb(0x60, 0x60, 0x60) },
        };

        private static readonly Dictionary<EdgeType, Color> EdgeColors = new()
        {
            { EdgeType.MemberOf,     Color.FromRgb(0x88, 0x17, 0x98) },
            { EdgeType.GpoLink,      Color.FromRgb(0xB1, 0x46, 0x00) },
            { EdgeType.PsoSubject,   Color.FromRgb(0xC5, 0x07, 0x1F) },
            { EdgeType.ParentChild,  Color.FromRgb(0x60, 0x60, 0x60) },
        };

        private static readonly Dictionary<ADObjectType, string> NodeIcons = new()
        {
            { ADObjectType.Domain,                "🌐" },
            { ADObjectType.OrganizationalUnit,    "📁" },
            { ADObjectType.User,                  "👤" },
            { ADObjectType.Group,                 "👥" },
            { ADObjectType.Computer,              "💻" },
            { ADObjectType.Policy,                "📋" },
            { ADObjectType.PasswordSettingsObject,"🔑" },
            { ADObjectType.GMSA,                  "🔐" },
            { ADObjectType.Container,             "📦" },
        };

        // ── État ────────────────────────────────────────────────────────────
        private List<GraphNode> _nodes = new();
        private List<GraphEdge> _edges = new();
        private ForceSimulation? _simulation;

        // Caméra (pan + zoom)
        private double _offsetX = 0, _offsetY = 0;
        private double _scale = 1.0;

        // Pan
        private bool _isPanning;
        private Point _panStart;

        // Drag nœud
        private GraphNode? _dragNode;
        private Point _dragStart;

        // Hover / sélection
        private GraphNode? _hoveredNode;
        private GraphNode? _selectedNode;

        // Timer pour la simulation
        private readonly DispatcherTimer _timer;
        private int _simStepsRemaining = 0;

        // Callback sélection
        public event Action<GraphNode?>? NodeSelected;

        public GraphCanvas()
        {
            ClipToBounds = true;
            Focusable = true;

            _timer = new DispatcherTimer { Interval = TimeSpan.FromMilliseconds(16) };
            _timer.Tick += (_, _) =>
            {
                if (_simStepsRemaining > 0)
                {
                    _simulation?.Step(2);
                    _simStepsRemaining -= 2;
                }
                InvalidateVisual();
            };
            _timer.Start();
        }

        // ── API publique ────────────────────────────────────────────────────

        public void LoadGraph(List<GraphNode> nodes, List<GraphEdge> edges)
        {
            _nodes = nodes;
            _edges = edges;
            _simulation = new ForceSimulation(_nodes, _edges);
            _simStepsRemaining = 300;
            FitView();
            InvalidateVisual();
        }

        public void ReLayout()
        {
            var rng = new Random();
            foreach (var n in _nodes)
            {
                double angle = 2 * Math.PI * rng.NextDouble();
                double r = 150 + rng.NextDouble() * 200;
                n.X = Math.Cos(angle) * r;
                n.Y = Math.Sin(angle) * r;
                n.Vx = n.Vy = 0;
            }
            _simulation = new ForceSimulation(_nodes, _edges);
            _simStepsRemaining = 300;
        }

        public void FitView()
        {
            if (_nodes.Count == 0) return;
            double minX = _nodes.Min(n => n.X - n.Radius);
            double maxX = _nodes.Max(n => n.X + n.Radius);
            double minY = _nodes.Min(n => n.Y - n.Radius);
            double maxY = _nodes.Max(n => n.Y + n.Radius);

            double graphW = maxX - minX + 80;
            double graphH = maxY - minY + 80;
            double scaleX = Bounds.Width > 0 ? Bounds.Width / graphW : 1;
            double scaleY = Bounds.Height > 0 ? Bounds.Height / graphH : 1;

            _scale = Math.Min(scaleX, scaleY);
            _scale = Math.Max(0.05, Math.Min(_scale, 3.0));

            double cx = (minX + maxX) / 2;
            double cy = (minY + maxY) / 2;
            _offsetX = Bounds.Width / 2 - cx * _scale;
            _offsetY = Bounds.Height / 2 - cy * _scale;
            InvalidateVisual();
        }

        public void ZoomIn() => Zoom(1.2, new Point(Bounds.Width / 2, Bounds.Height / 2));
        public void ZoomOut() => Zoom(0.8, new Point(Bounds.Width / 2, Bounds.Height / 2));

        // ── Rendu ────────────────────────────────────────────────────────────

        public override void Render(DrawingContext ctx)
        {
            // Fond
            ctx.DrawRectangle(new SolidColorBrush(Color.FromRgb(18, 20, 26)), null,
                new Rect(0, 0, Bounds.Width, Bounds.Height));

            if (_nodes.Count == 0)
            {
                DrawEmptyMessage(ctx);
                return;
            }

            // Transformation caméra
            using (ctx.PushTransform(Matrix.CreateTranslation(_offsetX, _offsetY) *
                                      Matrix.CreateScale(_scale, _scale)))
            {
                DrawEdges(ctx);
                DrawNodes(ctx);
            }

            DrawLegend(ctx);
            DrawStats(ctx);
        }

        private void DrawEdges(DrawingContext ctx)
        {
            foreach (var edge in _edges)
            {
                var color = EdgeColors.TryGetValue(edge.Type, out var c) ? c : Colors.Gray;
                bool isConnectedToSelected = _selectedNode != null &&
                    (edge.Source == _selectedNode || edge.Target == _selectedNode);

                var pen = new Pen(
                    new SolidColorBrush(isConnectedToSelected
                        ? Colors.White
                        : Color.FromArgb(160, color.R, color.G, color.B)),
                    isConnectedToSelected ? 2.0 : 1.2);

                var sx = edge.Source.X;
                var sy = edge.Source.Y;
                var tx = edge.Target.X;
                var ty = edge.Target.Y;

                // Vecteur direction
                double dx = tx - sx;
                double dy = ty - sy;
                double len = Math.Sqrt(dx * dx + dy * dy);
                if (len < 1) continue;

                // Raccourcir pour s'arrêter sur le bord du cercle
                double nx = dx / len, ny = dy / len;
                var start = new Point(sx + nx * edge.Source.Radius,
                                      sy + ny * edge.Source.Radius);
                var end   = new Point(tx - nx * (edge.Target.Radius + 8),
                                      ty - ny * (edge.Target.Radius + 8));

                ctx.DrawLine(pen, start, end);

                // Flèche
                DrawArrow(ctx, pen, end, nx, ny, 10);

                // Label sur le milieu de l'arête (uniquement si sélectionné ou hover)
                if (isConnectedToSelected)
                {
                    double mx = (start.X + end.X) / 2;
                    double my = (start.Y + end.Y) / 2;
                    DrawEdgeLabel(ctx, edge.Label, mx, my, color);
                }
            }
        }

        private static void DrawArrow(DrawingContext ctx, Pen pen, Point tip, double nx, double ny, double size)
        {
            double px = -ny, py = nx; // perpendiculaire
            var left  = new Point(tip.X - nx * size + px * size * 0.4,
                                   tip.Y - ny * size + py * size * 0.4);
            var right = new Point(tip.X - nx * size - px * size * 0.4,
                                   tip.Y - ny * size - py * size * 0.4);
            ctx.DrawLine(pen, tip, left);
            ctx.DrawLine(pen, tip, right);
        }

        private static void DrawEdgeLabel(DrawingContext ctx, string text, double x, double y, Color color)
        {
            var ft = new FormattedText(text,
                Avalonia.Media.Fonts.FontFamily.Default,
                Avalonia.Media.FontStyle.Normal,
                new Avalonia.Media.Fonts.FontWeight(),
                9,
                new SolidColorBrush(Color.FromArgb(220, color.R, color.G, color.B)));
            ctx.DrawRectangle(
                new SolidColorBrush(Color.FromArgb(160, 18, 20, 26)), null,
                new Rect(x - ft.Width / 2 - 3, y - ft.Height / 2 - 2, ft.Width + 6, ft.Height + 4));
            ctx.DrawText(ft, new Point(x - ft.Width / 2, y - ft.Height / 2));
        }

        private void DrawNodes(DrawingContext ctx)
        {
            foreach (var node in _nodes)
            {
                var baseColor = NodeColors.TryGetValue(node.NodeType, out var nc) ? nc : Colors.Gray;
                bool isSelected = node == _selectedNode;
                bool isHovered  = node == _hoveredNode;

                // Halo de sélection
                if (isSelected)
                {
                    ctx.DrawEllipse(null,
                        new Pen(new SolidColorBrush(Color.FromArgb(120, 255, 255, 255)), 3),
                        new Point(node.X, node.Y), node.Radius + 7, node.Radius + 7);
                }

                // Glow au hover
                if (isHovered && !isSelected)
                {
                    ctx.DrawEllipse(
                        new SolidColorBrush(Color.FromArgb(40, baseColor.R, baseColor.G, baseColor.B)),
                        null, new Point(node.X, node.Y), node.Radius + 10, node.Radius + 10);
                }

                // Cercle principal
                double brightness = isSelected ? 1.3 : isHovered ? 1.15 : 1.0;
                var fill = new SolidColorBrush(ScaleBrightness(baseColor, brightness));
                ctx.DrawEllipse(fill,
                    new Pen(new SolidColorBrush(Color.FromArgb(180, 255, 255, 255)), 1.2),
                    new Point(node.X, node.Y), node.Radius, node.Radius);

                // Icône
                var icon = NodeIcons.TryGetValue(node.NodeType, out var ic) ? ic : "?";
                var iconFt = new FormattedText(icon,
                    Avalonia.Media.Fonts.FontFamily.Default,
                    Avalonia.Media.FontStyle.Normal,
                    new Avalonia.Media.Fonts.FontWeight(),
                    node.Radius * 0.85,
                    Brushes.White);
                ctx.DrawText(iconFt, new Point(node.X - iconFt.Width / 2, node.Y - iconFt.Height / 2));

                // Label sous le nœud
                var labelFt = new FormattedText(TruncateLabel(node.Label, 20),
                    Avalonia.Media.Fonts.FontFamily.Default,
                    Avalonia.Media.FontStyle.Normal,
                    new Avalonia.Media.Fonts.FontWeight(),
                    11,
                    new SolidColorBrush(isSelected ? Colors.White : Color.FromArgb(220, 220, 220, 220)));

                double lx = node.X - labelFt.Width / 2;
                double ly = node.Y + node.Radius + 4;

                // Fond du label
                ctx.DrawRectangle(
                    new SolidColorBrush(Color.FromArgb(130, 18, 20, 26)), null,
                    new Rect(lx - 2, ly, labelFt.Width + 4, labelFt.Height));
                ctx.DrawText(labelFt, new Point(lx, ly));

                // Tier badge
                if (!string.IsNullOrEmpty(node.Tier))
                {
                    var tierFt = new FormattedText(node.Tier,
                        Avalonia.Media.Fonts.FontFamily.Default,
                        Avalonia.Media.FontStyle.Normal,
                        new Avalonia.Media.Fonts.FontWeight(),
                        8,
                        Brushes.White);
                    double tx = node.X + node.Radius * 0.5 - tierFt.Width / 2;
                    double ty = node.Y - node.Radius * 0.9;
                    ctx.DrawEllipse(new SolidColorBrush(Color.FromRgb(80, 80, 80)), null,
                        new Point(tx + tierFt.Width / 2, ty + tierFt.Height / 2),
                        tierFt.Width / 2 + 4, tierFt.Height / 2 + 2);
                    ctx.DrawText(tierFt, new Point(tx, ty));
                }
            }
        }

        private void DrawLegend(DrawingContext ctx)
        {
            var entries = new[]
            {
                (ADObjectType.Domain,                "Domain"),
                (ADObjectType.OrganizationalUnit,    "OU"),
                (ADObjectType.User,                  "User"),
                (ADObjectType.Group,                 "Group"),
                (ADObjectType.Computer,              "Computer"),
                (ADObjectType.Policy,                "GPO"),
                (ADObjectType.PasswordSettingsObject,"PSO"),
            };

            double lx = 12, ly = 12;
            ctx.DrawRectangle(new SolidColorBrush(Color.FromArgb(160, 18, 20, 26)),
                new Pen(new SolidColorBrush(Color.FromArgb(80, 255, 255, 255)), 1),
                new Rect(lx - 4, ly - 4, 120, entries.Length * 20 + 30));

            var titleFt = new FormattedText("Légende",
                Avalonia.Media.Fonts.FontFamily.Default, FontStyle.Normal,
                new Avalonia.Media.Fonts.FontWeight(), 11,
                new SolidColorBrush(Color.FromArgb(180, 255, 255, 255)));
            ctx.DrawText(titleFt, new Point(lx + 2, ly));
            ly += 18;

            foreach (var (type, label) in entries)
            {
                var color = NodeColors.TryGetValue(type, out var c) ? c : Colors.Gray;
                ctx.DrawEllipse(new SolidColorBrush(color), null, new Point(lx + 7, ly + 7), 7, 7);
                var ft = new FormattedText(label,
                    Avalonia.Media.Fonts.FontFamily.Default, FontStyle.Normal,
                    new Avalonia.Media.Fonts.FontWeight(), 11,
                    new SolidColorBrush(Color.FromArgb(200, 220, 220, 220)));
                ctx.DrawText(ft, new Point(lx + 18, ly));
                ly += 20;
            }
        }

        private void DrawStats(DrawingContext ctx)
        {
            var text = $"Nœuds: {_nodes.Count}  Arêtes: {_edges.Count}  [Scroll: zoom | Drag fond: pan | Drag nœud: déplacer]";
            var ft = new FormattedText(text,
                Avalonia.Media.Fonts.FontFamily.Default, FontStyle.Normal,
                new Avalonia.Media.Fonts.FontWeight(), 11,
                new SolidColorBrush(Color.FromArgb(140, 200, 200, 200)));
            ctx.DrawText(ft, new Point(Bounds.Width / 2 - ft.Width / 2, Bounds.Height - 22));
        }

        private void DrawEmptyMessage(DrawingContext ctx)
        {
            var ft = new FormattedText(
                "Aucune relation à afficher.\nConfigurez des relations (Memberships, GPO, PSO) puis rechargez.",
                Avalonia.Media.Fonts.FontFamily.Default, FontStyle.Normal,
                new Avalonia.Media.Fonts.FontWeight(), 16,
                new SolidColorBrush(Color.FromArgb(160, 180, 180, 180)));
            ctx.DrawText(ft, new Point(Bounds.Width / 2 - ft.Width / 2,
                                       Bounds.Height / 2 - ft.Height / 2));
        }

        // ── Interactions ─────────────────────────────────────────────────────

        protected override void OnPointerPressed(PointerPressedEventArgs e)
        {
            base.OnPointerPressed(e);
            var pos = e.GetPosition(this);
            var worldPos = ScreenToWorld(pos);

            var hit = HitTest(worldPos);
            if (hit != null)
            {
                _dragNode = hit;
                _dragStart = new Point(pos.X - hit.X * _scale - _offsetX,
                                       pos.Y - hit.Y * _scale - _offsetY);
                hit.IsDragging = true;
                _selectedNode = hit;
                NodeSelected?.Invoke(hit);
            }
            else
            {
                _isPanning = true;
                _panStart = new Point(pos.X - _offsetX, pos.Y - _offsetY);
                _selectedNode = null;
                NodeSelected?.Invoke(null);
            }
            e.Handled = true;
            InvalidateVisual();
        }

        protected override void OnPointerMoved(PointerMovedEventArgs e)
        {
            base.OnPointerMoved(e);
            var pos = e.GetPosition(this);

            if (_dragNode != null)
            {
                _dragNode.X = (pos.X - _dragStart.X - _offsetX) / _scale;
                _dragNode.Y = (pos.Y - _dragStart.Y - _offsetY) / _scale;
                _dragNode.Vx = _dragNode.Vy = 0;
            }
            else if (_isPanning)
            {
                _offsetX = pos.X - _panStart.X;
                _offsetY = pos.Y - _panStart.Y;
            }
            else
            {
                var worldPos = ScreenToWorld(pos);
                var prev = _hoveredNode;
                _hoveredNode = HitTest(worldPos);
                if (_hoveredNode != prev) InvalidateVisual();
                return;
            }
            InvalidateVisual();
        }

        protected override void OnPointerReleased(PointerReleasedEventArgs e)
        {
            base.OnPointerReleased(e);
            if (_dragNode != null)
            {
                _dragNode.IsDragging = false;
                _dragNode = null;
            }
            _isPanning = false;
        }

        protected override void OnPointerWheelChanged(PointerWheelEventArgs e)
        {
            base.OnPointerWheelChanged(e);
            var pos = e.GetPosition(this);
            double factor = e.Delta.Y > 0 ? 1.12 : 1.0 / 1.12;
            Zoom(factor, pos);
            e.Handled = true;
        }

        private void Zoom(double factor, Point center)
        {
            double newScale = Math.Max(0.05, Math.Min(_scale * factor, 5.0));
            double sf = newScale / _scale;
            _offsetX = center.X - (center.X - _offsetX) * sf;
            _offsetY = center.Y - (center.Y - _offsetY) * sf;
            _scale = newScale;
            InvalidateVisual();
        }

        // ── Utilitaires ───────────────────────────────────────────────────────

        private Point ScreenToWorld(Point screen)
            => new Point((screen.X - _offsetX) / _scale, (screen.Y - _offsetY) / _scale);

        private GraphNode? HitTest(Point world)
            => _nodes.FirstOrDefault(n =>
            {
                double dx = world.X - n.X, dy = world.Y - n.Y;
                return Math.Sqrt(dx * dx + dy * dy) <= n.Radius + 4;
            });

        private static Color ScaleBrightness(Color c, double f)
        {
            byte Clamp(double v) => (byte)Math.Max(0, Math.Min(255, v));
            return Color.FromRgb(Clamp(c.R * f), Clamp(c.G * f), Clamp(c.B * f));
        }

        private static string TruncateLabel(string s, int max)
            => s.Length > max ? s[..max] + "…" : s;
    }
}
