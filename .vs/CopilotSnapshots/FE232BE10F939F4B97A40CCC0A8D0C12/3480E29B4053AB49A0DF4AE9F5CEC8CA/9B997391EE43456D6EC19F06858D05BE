using System;
using System.IO;
using System.Text;
using System.Threading.Tasks;

namespace Activedirectory.Services
{
    /// <summary>
    /// Génère un script PowerShell qui interroge un domaine AD réel
    /// et produit un fichier JSON importable dans l'application.
    /// </summary>
    public class ADImportPowerShellService
    {
        /// <summary>
        /// Écrit le script PowerShell d'import dans <paramref name="filePath"/>.
        /// </summary>
        public async Task<bool> GenerateImportScriptAsync(string filePath)
        {
            try
            {
                var sb = new StringBuilder();
                sb.AppendLine(BuildScript());
                await File.WriteAllTextAsync(filePath, sb.ToString(), new UTF8Encoding(encoderShouldEmitUTF8Identifier: true));
                return true;
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Erreur génération script import : {ex.Message}");
                return false;
            }
        }

        // ----------------------------------------------------------------
        // Script PowerShell
        // ----------------------------------------------------------------
        private static string BuildScript() => @"
<#
.SYNOPSIS
    Export Active Directory vers un fichier JSON importable dans Active Directory Simulator.

.DESCRIPTION
    Ce script lit la structure d'un domaine Active Directory (OUs, Containers, Users,
    Groups, Computers, GMSAs, GPOs, PSOs) et produit un JSON au format attendu
    par l'application Active Directory Simulator.

.PARAMETER OutputPath
    Chemin du fichier JSON de sortie.
    Par défaut : .\AD_Export.json dans le répertoire courant.

.PARAMETER DomainDN
    Distinguished Name du domaine cible.
    Par défaut : domaine courant détecté automatiquement.

.EXAMPLE
    .\Export-ADToSimulator.ps1
    .\Export-ADToSimulator.ps1 -OutputPath C:\Exports\mon_domaine.json
    .\Export-ADToSimulator.ps1 -DomainDN ""DC=contoso,DC=com"" -OutputPath C:\Exports\contoso.json

.NOTES
    Requires : ActiveDirectory PowerShell module (RSAT)
    Rights   : Domain Read (standard domain user is sufficient)
#>

param(
    [string]$OutputPath = "".\AD_Export.json"",
    [string]$DomainDN   = """"
)

Set-StrictMode -Version Latest
$ErrorActionPreference = ""Stop""

# ── 1. Prérequis ──────────────────────────────────────────────────────────────
if (-not (Get-Module -ListAvailable -Name ActiveDirectory)) {
    Write-Error ""Le module ActiveDirectory (RSAT) est requis. Installez-le via : Add-WindowsCapability -Online -Name Rsat.ActiveDirectory.DS-LDS.Tools~~~~0.0.1.0""
    exit 1
}
Import-Module ActiveDirectory -ErrorAction Stop

# ── 2. Domaine cible ──────────────────────────────────────────────────────────
if ([string]::IsNullOrWhiteSpace($DomainDN)) {
    $domain    = Get-ADDomain
    $DomainDN  = $domain.DistinguishedName
    $domainName = $domain.DNSRoot
} else {
    # Reconstruire le FQDN depuis le DN (DC=contoso,DC=com → contoso.com)
    $domainName = ($DomainDN -replace ""DC="","" -replace "",DC="","."").Trim("","").Trim()
}

Write-Host ""Domaine cible : $domainName ($DomainDN)"" -ForegroundColor Cyan

# ── 3. Helpers ────────────────────────────────────────────────────────────────

# Échappe les chaînes pour JSON
function ConvertTo-JsonString([string]$s) {
    if ($null -eq $s) { return """" }
    $s = $s.Replace(""\\"", ""\\\\"").Replace("""""", ""\"""").Replace(""`n"", ""\n"").Replace(""`r"", ""\r"").Replace(""`t"", ""\t"")
    return $s
}

# Convertit une date .NET en ISO 8601 ou chaîne vide
function Format-Date($d) {
    if ($null -eq $d) { return (Get-Date -Format ""o"") }
    try { return ([datetime]$d).ToString(""o"") } catch { return (Get-Date -Format ""o"") }
}

# Retourne le type SimAD depuis la classe AD
function Get-SimType([string]$objectClass, [string]$objectCategory) {
    switch ($objectClass) {
        ""organizationalUnit""        { return ""OrganizationalUnit"" }
        ""container""                 { return ""Container"" }
        ""builtinDomain""             { return ""Container"" }
        ""user""                      { return ""User"" }
        ""group""                     { return ""Group"" }
        ""computer""                  { return ""Computer"" }
        ""msDS-GroupManagedServiceAccount"" { return ""GMSA"" }
        ""groupPolicyContainer""      { return ""Policy"" }
        ""msDS-PasswordSettings""     { return ""PasswordSettingsObject"" }
        default                       { return ""Container"" }
    }
}

# ── 4. Collecte des GPOs (liste plate) ───────────────────────────────────────
Write-Host ""Collecte des GPOs..."" -ForegroundColor Yellow
$gpoMap = @{}   # DN → DisplayName
try {
    Get-ADObject -Filter { objectClass -eq ""groupPolicyContainer"" } `
                 -SearchBase $DomainDN `
                 -Properties DisplayName, cn | ForEach-Object {
        $gpoMap[$_.DistinguishedName] = if ($_.DisplayName) { $_.DisplayName } else { $_.cn }
    }
} catch {
    Write-Warning ""Impossible de lire les GPOs : $_""
}

# ── 5. Collecte des liens GPO par OU/Domain ───────────────────────────────────
Write-Host ""Collecte des liens GPO..."" -ForegroundColor Yellow
$gpoLinks = @{}  # DN de l'OU → [array] noms de GPO

function Get-GPOLinksForDN([string]$dn) {
    try {
        $obj = Get-ADObject -Identity $dn -Properties gpLink
        if ($obj.gpLink) {
            $links = [regex]::Matches($obj.gpLink, ""\[LDAP://([^\]]+);"") | ForEach-Object { $_.Groups[1].Value }
            $names = foreach ($link in $links) {
                if ($gpoMap.ContainsKey($link)) { $gpoMap[$link] } else { $link }
            }
            return @($names)
        }
    } catch {}
    return @()
}

# ── 6. Collecte des PSOs ─────────────────────────────────────────────────────
Write-Host ""Collecte des PSOs..."" -ForegroundColor Yellow
$psoObjects = @()
try {
    $psoObjects = Get-ADFineGrainedPasswordPolicy -Filter * | Select-Object `
        Name, DistinguishedName, Precedence,
        MinPasswordLength, PasswordHistoryCount, ComplexityEnabled,
        MaxPasswordAge, MinPasswordAge,
        LockoutThreshold, LockoutDuration, LockoutObservationWindow,
        AppliesTo
} catch {
    Write-Warning ""Impossible de lire les PSOs (droits insuffisants ?) : $_""
}

# ── 7. Collecte des membres de groupes ───────────────────────────────────────
Write-Host ""Collecte des groupes et memberships..."" -ForegroundColor Yellow
$groupMembers = @{}   # SAMAccountName du groupe → [array] SAMAccountName des membres
try {
    Get-ADGroup -Filter * -SearchBase $DomainDN -Properties Members, SAMAccountName | ForEach-Object {
        $sam = $_.SAMAccountName
        $members = @()
        foreach ($memberDN in $_.Members) {
            try {
                $m = Get-ADObject -Identity $memberDN -Properties SAMAccountName
                if ($m.SAMAccountName) { $members += $m.SAMAccountName }
            } catch {}
        }
        $groupMembers[$sam] = $members
    }
} catch {
    Write-Warning ""Impossible de lire les membres de groupes : $_""
}

# ── 8. Construction récursive de l'arbre ─────────────────────────────────────

function Build-NodeJson {
    param(
        [string]$dn,
        [string]$name,
        [string]$simType,
        [object]$adObj,
        [int]$depth = 0
    )

    $indent  = ""  "" * $depth
    $indent2 = ""  "" * ($depth + 1)

    $id          = [guid]::NewGuid().ToString()
    $description = if ($adObj -and $adObj.Description) { ConvertTo-JsonString ($adObj.Description | Out-String).Trim() } else { """" }
    $created     = if ($adObj -and $adObj.WhenCreated) { Format-Date $adObj.WhenCreated } else { Format-Date $null }
    $modified    = if ($adObj -and $adObj.WhenChanged) { Format-Date $adObj.WhenChanged } else { Format-Date $null }
    $sam         = if ($adObj -and $adObj.SAMAccountName) { $adObj.SAMAccountName } else { """" }

    # Tier par convention de nommage / OU (heuristique simple)
    $tier = """"
    if ($simType -in @(""User"",""Group"",""Computer"",""GMSA"",""OrganizationalUnit"",""PasswordSettingsObject"")) {
        if ($dn -match ""Tier.?0|Admin|Domain Controllers|DomainControllers"") { $tier = ""Tier 0"" }
        elseif ($dn -match ""Tier.?1|Server"") { $tier = ""Tier 1"" }
        elseif ($dn -match ""Tier.?2|Workstation|Users|Computers"") { $tier = ""Tier 2"" }
    }

    # MemberOf (pour User / Group)
    $memberOfJson = ""[]""
    if ($adObj -and $adObj.MemberOf) {
        $memberOfNames = foreach ($groupDN in $adObj.MemberOf) {
            try { (Get-ADObject -Identity $groupDN -Properties SAMAccountName).SAMAccountName } catch { $null }
        }
        $memberOfNames = $memberOfNames | Where-Object { $_ }
        if ($memberOfNames) {
            $memberOfJson = ""["" + (($memberOfNames | ForEach-Object { """""" + (ConvertTo-JsonString $_) + """""" }) -join "","") + ""]""
        }
    }

    # LinkedGPOs (pour OU et Domain)
    $linkedGPOJson = ""[]""
    if ($simType -in @(""OrganizationalUnit"",""Domain"")) {
        $links = Get-GPOLinksForDN $dn
        if ($links.Count -gt 0) {
            $linkedGPOJson = ""["" + (($links | ForEach-Object { """""" + (ConvertTo-JsonString $_) + """""" }) -join "","") + ""]""
        }
    }

    # PSOAppliesTo (pour PSO)
    $psoAppliesToJson = ""[]""
    $psoPrec          = ""null""
    $psoMinLen        = ""null""
    $psoHistory       = ""null""
    $psoComplex       = ""null""
    $psoMaxAge        = ""null""
    $psoMinAge        = ""null""
    $psoLockThr       = ""null""
    $psoLockDur       = ""null""
    $psoLockObs       = ""null""

    if ($simType -eq ""PasswordSettingsObject"") {
        $pso = $psoObjects | Where-Object { $_.DistinguishedName -eq $dn } | Select-Object -First 1
        if ($pso) {
            $psoPrec    = $pso.Precedence
            $psoMinLen  = $pso.MinPasswordLength
            $psoHistory = $pso.PasswordHistoryCount
            $psoComplex = ($pso.ComplexityEnabled).ToString().ToLower()
            $psoMaxAge  = if ($pso.MaxPasswordAge) { [int]$pso.MaxPasswordAge.TotalDays } else { ""null"" }
            $psoMinAge  = if ($pso.MinPasswordAge) { [int]$pso.MinPasswordAge.TotalDays } else { ""null"" }
            $psoLockThr = $pso.LockoutThreshold
            $psoLockDur = if ($pso.LockoutDuration) { [int]$pso.LockoutDuration.TotalMinutes } else { ""null"" }
            $psoLockObs = if ($pso.LockoutObservationWindow) { [int]$pso.LockoutObservationWindow.TotalMinutes } else { ""null"" }

            $appliesToSAMs = foreach ($subjectDN in $pso.AppliesTo) {
                try { (Get-ADObject -Identity $subjectDN -Properties SAMAccountName).SAMAccountName } catch { $null }
            }
            $appliesToSAMs = $appliesToSAMs | Where-Object { $_ }
            if ($appliesToSAMs) {
                $psoAppliesToJson = ""["" + (($appliesToSAMs | ForEach-Object { """""" + (ConvertTo-JsonString $_) + """""" }) -join "","") + ""]""
            }
        }
    }

    # ── Enfants ───────────────────────────────────────────────────────────────
    $childJsonParts = @()

    # Sous-OUs et Containers
    try {
        $childOUs = Get-ADObject -Filter { (objectClass -eq ""organizationalUnit"") -or (objectClass -eq ""container"") -or (objectClass -eq ""builtinDomain"") } `
                                 -SearchBase $dn -SearchScope OneLevel -Properties WhenCreated, WhenChanged, Description, gpLink
        foreach ($child in $childOUs) {
            $ct = Get-SimType $child.ObjectClass """"
            $childJsonParts += Build-NodeJson -dn $child.DistinguishedName -name $child.Name -simType $ct -adObj $child -depth ($depth + 1)
        }
    } catch {}

    # Feuilles dans cette OU (Users, Computers, Groups, GMSAs, GPOs, PSOs)
    try {
        $leaves = Get-ADObject -Filter {
            (objectClass -eq ""user"") -or
            (objectClass -eq ""group"") -or
            (objectClass -eq ""computer"") -or
            (objectClass -eq ""msDS-GroupManagedServiceAccount"") -or
            (objectClass -eq ""groupPolicyContainer"") -or
            (objectClass -eq ""msDS-PasswordSettings"")
        } -SearchBase $dn -SearchScope OneLevel `
          -Properties SAMAccountName, MemberOf, WhenCreated, WhenChanged, Description, ObjectClass

        foreach ($leaf in $leaves) {
            $lt = Get-SimType $leaf.ObjectClass """"
            $childJsonParts += Build-NodeJson -dn $leaf.DistinguishedName -name $leaf.Name -simType $lt -adObj $leaf -depth ($depth + 1)
        }
    } catch {}

    $childrenJson = if ($childJsonParts.Count -gt 0) {
        ""`n$indent2["" + ($childJsonParts -join "","") + ""`n$indent2]""
    } else { ""[]"" }

    # ── Sérialisation JSON ─────────────────────────────────────────────────────
    return @""
$indent{
$indent2""Id"": ""$id"",
$indent2""Name"": ""$(ConvertTo-JsonString $name)"",
$indent2""Type"": ""$simType"",
$indent2""Description"": ""$description"",
$indent2""DistinguishedName"": ""$(ConvertTo-JsonString $dn)"",
$indent2""Tier"": $(if ($tier) { """""" + $tier + """""" } else { ""null"" }),
$indent2""Children"": $childrenJson,
$indent2""MemberOf"": $memberOfJson,
$indent2""LinkedGPOs"": $linkedGPOJson,
$indent2""PSOAppliesTo"": $psoAppliesToJson,
$indent2""PSOPrecedence"": $psoPrec,
$indent2""PSOMinPasswordLength"": $psoMinLen,
$indent2""PSOPasswordHistoryCount"": $psoHistory,
$indent2""PSOComplexityEnabled"": $psoComplex,
$indent2""PSOMaxPasswordAgeDays"": $psoMaxAge,
$indent2""PSOMinPasswordAgeDays"": $psoMinAge,
$indent2""PSOLockoutThreshold"": $psoLockThr,
$indent2""PSOLockoutDurationMinutes"": $psoLockDur,
$indent2""PSOLockoutObservationWindowMinutes"": $psoLockObs,
$indent2""CreatedDate"": ""$created"",
$indent2""ModifiedDate"": ""$modified""
$indent}
""@
}

# ── 9. Construction racine (Domain) ──────────────────────────────────────────
Write-Host ""Construction de l'arbre..."" -ForegroundColor Yellow

$domainObj = Get-ADDomain
$rootJson  = Build-NodeJson -dn $DomainDN -name $domainName -simType ""Domain"" -adObj $domainObj -depth 0

# ── 10. Écriture du fichier ───────────────────────────────────────────────────
$outputDir = Split-Path $OutputPath -Parent
if ($outputDir -and -not (Test-Path $outputDir)) {
    New-Item -ItemType Directory -Path $outputDir -Force | Out-Null
}

$rootJson | Out-File -FilePath $OutputPath -Encoding UTF8 -Force

Write-Host """"
Write-Host ""===================================="" -ForegroundColor Green
Write-Host "" Export terminé avec succès !"" -ForegroundColor Green
Write-Host "" Fichier : $OutputPath"" -ForegroundColor Green
Write-Host ""===================================="" -ForegroundColor Green
Write-Host "" Importez ce fichier dans Active Directory Simulator"" -ForegroundColor Cyan
Write-Host "" via : Fichier > Ouvrir / File > Open"" -ForegroundColor Cyan
";
    }
}
