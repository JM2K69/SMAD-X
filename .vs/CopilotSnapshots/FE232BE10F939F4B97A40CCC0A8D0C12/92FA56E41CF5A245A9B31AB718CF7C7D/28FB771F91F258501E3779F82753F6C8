<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Activedirectory.ViewModels"
        x:Class="Activedirectory.Views.RelationsWindow"
        x:DataType="vm:RelationsViewModel"
        Title="🔗 Relations entre objets AD"
        Width="860" Height="640"
        WindowStartupLocation="CenterOwner"
        CanResize="True">

    <Window.Styles>
        <!-- En-tête de colonne -->
        <Style Selector="Border.RelHeader">
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
        <!-- Ligne paire -->
        <Style Selector="Border.RelRow">
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderBrush" Value="#EEEEEE"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="*,Auto">

        <TabControl Grid.Row="0" Margin="10">

            <!-- ===== ONGLET MEMBERSHIPS ===== -->
            <TabItem Header="👥 Appartenances aux groupes">
                <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="8">

                    <!-- Formulaire d'ajout -->
                    <Border Grid.Row="0" BorderBrush="LightGray" BorderThickness="1"
                            CornerRadius="4" Padding="10" Margin="0,0,0,6">
                        <Grid ColumnDefinitions="*,30,*,10,Auto" RowDefinitions="Auto,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Objet source (user / groupe)"
                                       FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Groupe cible"
                                       FontWeight="SemiBold" Margin="0,0,0,4"/>

                            <ComboBox Grid.Row="1" Grid.Column="0"
                                      SelectedItem="{Binding MembershipSource, Mode=TwoWay}"
                                      ItemsSource="{Binding AvailableMembershipTargets}"
                                      PlaceholderText="Choisir un objet…"
                                      HorizontalAlignment="Stretch"/>

                            <TextBlock Grid.Row="1" Grid.Column="1"
                                       Text="→" FontSize="18" VerticalAlignment="Center"
                                       HorizontalAlignment="Center" Foreground="#0078D4"/>

                            <ComboBox Grid.Row="1" Grid.Column="2"
                                      SelectedItem="{Binding MembershipTarget, Mode=TwoWay}"
                                      ItemsSource="{Binding AvailableGroups}"
                                      PlaceholderText="Choisir un groupe…"
                                      HorizontalAlignment="Stretch"/>

                            <Button Grid.Row="1" Grid.Column="4"
                                    Content="➕ Ajouter"
                                    Command="{Binding AddMembershipCommand}"
                                    Padding="12,6" Background="#0078D4" Foreground="White"
                                    VerticalAlignment="Bottom"/>
                        </Grid>
                    </Border>

                    <!-- En-tête de liste -->
                    <Grid Grid.Row="1" ColumnDefinitions="200,100,200,*">
                        <Border Grid.Column="0" Classes="RelHeader"><TextBlock Text="Source" FontWeight="SemiBold"/></Border>
                        <Border Grid.Column="1" Classes="RelHeader"><TextBlock Text="Type" FontWeight="SemiBold"/></Border>
                        <Border Grid.Column="2" Classes="RelHeader"><TextBlock Text="→ Groupe" FontWeight="SemiBold"/></Border>
                        <Border Grid.Column="3" Classes="RelHeader"><TextBlock Text="Relation" FontWeight="SemiBold"/></Border>
                    </Grid>

                    <!-- Liste -->
                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding Memberships}"
                             SelectedItem="{Binding SelectedMembership, Mode=TwoWay}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:RelationEntry">
                                <Grid ColumnDefinitions="200,100,200,*">
                                    <Border Grid.Column="0" Classes="RelRow"><TextBlock Text="{Binding Source}" TextTrimming="CharacterEllipsis"/></Border>
                                    <Border Grid.Column="1" Classes="RelRow"><TextBlock Text="{Binding SourceType}"/></Border>
                                    <Border Grid.Column="2" Classes="RelRow"><TextBlock Text="{Binding Target}" TextTrimming="CharacterEllipsis"/></Border>
                                    <Border Grid.Column="3" Classes="RelRow"><TextBlock Text="{Binding RelationType}"/></Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Actions -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
                        <Button Content="🗑️ Supprimer la sélection"
                                Command="{Binding RemoveMembershipCommand}"
                                Padding="10,5" Background="#FFDDDD"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ===== ONGLET GPO LINKS ===== -->
            <TabItem Header="📋 Liens GPO → OU">
                <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="8">

                    <Border Grid.Row="0" BorderBrush="LightGray" BorderThickness="1"
                            CornerRadius="4" Padding="10" Margin="0,0,0,6">
                        <Grid ColumnDefinitions="*,30,*,10,Auto" RowDefinitions="Auto,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="GPO"
                                       FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="OU cible"
                                       FontWeight="SemiBold" Margin="0,0,0,4"/>

                            <ComboBox Grid.Row="1" Grid.Column="0"
                                      SelectedItem="{Binding GpoLinkGpo, Mode=TwoWay}"
                                      ItemsSource="{Binding AvailableGPOs}"
                                      PlaceholderText="Choisir une GPO…"
                                      HorizontalAlignment="Stretch"/>

                            <TextBlock Grid.Row="1" Grid.Column="1"
                                       Text="→" FontSize="18" VerticalAlignment="Center"
                                       HorizontalAlignment="Center" Foreground="#107C10"/>

                            <ComboBox Grid.Row="1" Grid.Column="2"
                                      SelectedItem="{Binding GpoLinkOu, Mode=TwoWay}"
                                      ItemsSource="{Binding AvailableOUs}"
                                      PlaceholderText="Choisir une OU…"
                                      HorizontalAlignment="Stretch"/>

                            <Button Grid.Row="1" Grid.Column="4"
                                    Content="➕ Lier"
                                    Command="{Binding AddGpoLinkCommand}"
                                    Padding="12,6" Background="#107C10" Foreground="White"
                                    VerticalAlignment="Bottom"/>
                        </Grid>
                    </Border>

                    <!-- En-tête -->
                    <Grid Grid.Row="1" ColumnDefinitions="260,*">
                        <Border Grid.Column="0" Classes="RelHeader"><TextBlock Text="OU" FontWeight="SemiBold"/></Border>
                        <Border Grid.Column="1" Classes="RelHeader"><TextBlock Text="→ GPO liée" FontWeight="SemiBold"/></Border>
                    </Grid>

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding GpoLinks}"
                             SelectedItem="{Binding SelectedGpoLink, Mode=TwoWay}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:RelationEntry">
                                <Grid ColumnDefinitions="260,*">
                                    <Border Grid.Column="0" Classes="RelRow"><TextBlock Text="{Binding Source}" TextTrimming="CharacterEllipsis"/></Border>
                                    <Border Grid.Column="1" Classes="RelRow"><TextBlock Text="{Binding Target}" TextTrimming="CharacterEllipsis"/></Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
                        <Button Content="🗑️ Supprimer la sélection"
                                Command="{Binding RemoveGpoLinkCommand}"
                                Padding="10,5" Background="#FFDDDD"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ===== ONGLET PSO ===== -->
            <TabItem Header="🔑 PSO → Utilisateurs/Groupes">
                <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="8">

                    <Border Grid.Row="0" BorderBrush="LightGray" BorderThickness="1"
                            CornerRadius="4" Padding="10" Margin="0,0,0,6">
                        <Grid ColumnDefinitions="*,30,*,10,Auto" RowDefinitions="Auto,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="PSO"
                                       FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Utilisateur / Groupe cible"
                                       FontWeight="SemiBold" Margin="0,0,0,4"/>

                            <ComboBox Grid.Row="1" Grid.Column="0"
                                      SelectedItem="{Binding PsoLinkPso, Mode=TwoWay}"
                                      ItemsSource="{Binding AvailablePSOs}"
                                      PlaceholderText="Choisir un PSO…"
                                      HorizontalAlignment="Stretch"/>

                            <TextBlock Grid.Row="1" Grid.Column="1"
                                       Text="→" FontSize="18" VerticalAlignment="Center"
                                       HorizontalAlignment="Center" Foreground="#CA5010"/>

                            <ComboBox Grid.Row="1" Grid.Column="2"
                                      SelectedItem="{Binding PsoLinkTarget, Mode=TwoWay}"
                                      ItemsSource="{Binding AvailableMembershipTargets}"
                                      PlaceholderText="Choisir un utilisateur ou groupe…"
                                      HorizontalAlignment="Stretch"/>

                            <Button Grid.Row="1" Grid.Column="4"
                                    Content="➕ Appliquer"
                                    Command="{Binding AddPsoLinkCommand}"
                                    Padding="12,6" Background="#CA5010" Foreground="White"
                                    VerticalAlignment="Bottom"/>
                        </Grid>
                    </Border>

                    <!-- En-tête -->
                    <Grid Grid.Row="1" ColumnDefinitions="220,*">
                        <Border Grid.Column="0" Classes="RelHeader"><TextBlock Text="PSO" FontWeight="SemiBold"/></Border>
                        <Border Grid.Column="1" Classes="RelHeader"><TextBlock Text="→ Sujet (User / Groupe)" FontWeight="SemiBold"/></Border>
                    </Grid>

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding PsoLinks}"
                             SelectedItem="{Binding SelectedPsoLink, Mode=TwoWay}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:RelationEntry">
                                <Grid ColumnDefinitions="220,*">
                                    <Border Grid.Column="0" Classes="RelRow"><TextBlock Text="{Binding Source}" TextTrimming="CharacterEllipsis"/></Border>
                                    <Border Grid.Column="1" Classes="RelRow"><TextBlock Text="{Binding Target}" TextTrimming="CharacterEllipsis"/></Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
                        <Button Content="🗑️ Supprimer la sélection"
                                Command="{Binding RemovePsoLinkCommand}"
                                Padding="10,5" Background="#FFDDDD"/>
                    </StackPanel>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- Barre de statut + bouton Fermer -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="10,0,10,10">
            <Border Grid.Column="0" Background="#F3F3F3" CornerRadius="4" Padding="8,4">
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" FontSize="12"/>
            </Border>
            <Button Grid.Column="1" Content="✔ Fermer" Click="OnCloseClick"
                    Padding="16,6" Margin="10,0,0,0" Background="#0078D4" Foreground="White"/>
        </Grid>
    </Grid>
</Window>
