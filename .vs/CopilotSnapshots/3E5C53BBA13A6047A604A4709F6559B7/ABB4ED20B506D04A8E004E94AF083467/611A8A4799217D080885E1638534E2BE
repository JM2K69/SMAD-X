<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SMADX.App"
             xmlns:local="using:Activedirectory"
             xmlns:converters="using:Activedirectory.Converters"
             xmlns:helpers="using:Activedirectory.Helpers"
             RequestedThemeVariant="Light">

    <Application.Resources>
        <converters:BoolToStringConverter x:Key="BoolToStringConverter"/>
        <converters:MarkdownConverter x:Key="MarkdownConverter"/>
        <helpers:LocalizationProxy x:Key="Loc"/>
    </Application.Resources>

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://SMADX/Styles/LightTheme.axaml"/>
    </Application.Styles>
</Application>
