<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="300"
        x:Class="Activedirectory.Views.NewDomainDialog"
        Title="Créer un nouveau domaine Active Directory"
        Width="500" Height="300"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <Grid Margin="20" RowDefinitions="Auto,Auto,Auto,*,Auto">

        <!-- Titre -->
        <TextBlock Grid.Row="0" 
                   Text="Nouveau domaine Active Directory" 
                   FontSize="18" 
                   FontWeight="Bold" 
                   Margin="0,0,0,20"/>

        <!-- Description -->
        <TextBlock Grid.Row="1" 
                   TextWrapping="Wrap" 
                   Margin="0,0,0,20">
            <Run Text="Créez une nouvelle structure Active Directory vierge avec tous les conteneurs, OUs et groupes par défaut."/>
        </TextBlock>

        <!-- Saisie du nom de domaine -->
        <StackPanel Grid.Row="2" Spacing="10" Margin="0,0,0,20">
            <TextBlock Text="Nom du domaine (FQDN) :" FontWeight="SemiBold"/>
            <TextBox Name="DomainNameTextBox" 
                     Watermark="ex: contoso.com, enterprise.local"
                     Text="contoso.com"/>

            <TextBlock Name="ValidationMessage" 
                       Foreground="Red" 
                       FontSize="12" 
                       IsVisible="False"
                       Text="Le nom de domaine doit contenir au moins un point (ex: domaine.com)"/>

            <!-- Option Tiering -->
            <CheckBox Name="EnableTieringCheckBox" 
                      Content="Activer le modèle de tiering (Tier 0/1/2)" 
                      IsChecked="True"
                      Margin="0,10,0,0">
                <CheckBox.ToolTip>
                    <ToolTip>
                        <TextBlock TextWrapping="Wrap" MaxWidth="300">
                            Si coché, les utilisateurs, groupes et objets seront automatiquement affectés à des tiers selon leur rôle :
                            • Tier 0 : Comptes privilégiés (Administrator, Domain Admins, Enterprise Admins, etc.)
                            • Tier 1 : Serveurs et groupes de gestion
                            • Tier 2 : Postes de travail et utilisateurs standards
                        </TextBlock>
                    </ToolTip>
                </CheckBox.ToolTip>
            </CheckBox>
        </StackPanel>

        <!-- Aperçu -->
        <Border Grid.Row="3" 
                BorderBrush="#CCCCCC" 
                BorderThickness="1" 
                Background="#F9F9F9" 
                Padding="10"
                Margin="0,0,0,20">
            <ScrollViewer MaxHeight="150">
                <TextBlock TextWrapping="Wrap" FontSize="11" FontFamily="Consolas">
                    <Run Text="Structure qui sera créée :" FontWeight="Bold"/>
                    <LineBreak/>
                    <Run Text="📦 Users (container par défaut)"/>
                    <LineBreak/>
                    <Run Text="📦 Computers (container par défaut)"/>
                    <LineBreak/>
                    <Run Text="📦 System (container système)"/>
                    <LineBreak/>
                    <Run Text="   └─ 📦 Password Settings Container"/>
                    <LineBreak/>
                    <Run Text="📦 Builtin (groupes intégrés)"/>
                    <LineBreak/>
                    <Run Text="📁 Domain Controllers (OU)"/>
                    <LineBreak/>
                    <Run Text="🔐 Krbtgt (compte)"/>
                    <LineBreak/>
                    <Run Text="👤 Administrator"/>
                    <LineBreak/>
                    <Run Text="👥 Domain Admins, Enterprise Admins, etc."/>
                </TextBlock>
            </ScrollViewer>
        </Border>

        <!-- Boutons -->
        <StackPanel Grid.Row="4" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Spacing="10">
            <Button Content="Annuler" 
                    Width="100" 
                    Click="OnCancelClick"/>
            <Button Content="Créer" 
                    Width="100" 
                    Click="OnCreateClick"
                    IsDefault="True"/>
        </StackPanel>

    </Grid>
</Window>
