<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Activedirectory.ViewModels"
        xmlns:services="using:Activedirectory.Services"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="800"
        x:Class="Activedirectory.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Active Directory Simulator"
        Width="1400" Height="855">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Menu et Toolbar -->
        <Grid Grid.Row="0" RowDefinitions="Auto,Auto">
            <!-- Menu principal -->
            <Menu Grid.Row="0" x:Name="MainMenu" DataContext="{x:Static services:LocalizationService.Instance}">
                <MenuItem Header="{Binding [Menu.File]}">
                    <MenuItem Header="{Binding [Menu.File.NewDomain]}" Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).CreateNewDomainCommand}" InputGesture="Ctrl+N"/>
                    <MenuItem Header="{Binding [Menu.File.NewStructure]}" Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).InitializeSampleDataCommand}" InputGesture="Ctrl+Shift+N"/>
                    <Separator/>
                    <MenuItem Header="{Binding [Menu.File.Open]}" Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).LoadFromFileCommand}" InputGesture="Ctrl+O"/>
                    <MenuItem Header="{Binding [Menu.File.Save]}" Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).SaveToFileCommand}" InputGesture="Ctrl+S"/>
                    <Separator/>
                    <MenuItem Header="{Binding [Menu.File.ExportJson]}" Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ExportToJsonCommand}" InputGesture="Ctrl+E"/>
                    <MenuItem Header="{Binding [Menu.File.ExportPowerShell]}" Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ExportToPowerShellCommand}" InputGesture="Ctrl+P"/>
                    <Separator/>
                    <MenuItem Header="{Binding [Menu.File.Exit]}" Click="OnExitClick" InputGesture="Alt+F4"/>
                </MenuItem>
                <MenuItem Header="{Binding [Menu.Edit]}">
                    <MenuItem Header="{Binding [Menu.Edit.Copy]}" Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).CopyObjectCommand}" InputGesture="Ctrl+C"/>
                    <MenuItem Header="{Binding [Menu.Edit.Paste]}" Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).PasteObjectCommand}" InputGesture="Ctrl+V"/>
                    <Separator/>
                    <MenuItem Header="{Binding [Menu.Edit.Rename]}" Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).RenameObjectCommand}" InputGesture="F2"/>
                    <MenuItem Header="{Binding [Menu.Edit.Delete]}" Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).DeleteObjectCommand}" InputGesture="Delete"/>
                    <Separator/>
                    <MenuItem Header="{Binding [Menu.Edit.AddPSO]}" Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).AddPasswordSettingsObjectCommand}"/>
                </MenuItem>
                <MenuItem Header="{Binding [Menu.View]}">
                    <MenuItem Header="{Binding [Menu.View.ExpandAll]}" Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ExpandAllCommand}"/>
                    <MenuItem Header="{Binding [Menu.View.CollapseAll]}" Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).CollapseAllCommand}"/>
                    <Separator/>
                    <MenuItem Header="{Binding [Menu.View.Theme]}">
                        <MenuItem Header="{Binding [Menu.View.Theme.Light]}" Click="OnLightThemeClick"/>
                        <MenuItem Header="{Binding [Menu.View.Theme.Dark]}" Click="OnDarkThemeClick"/>
                    </MenuItem>
                    <MenuItem Header="{Binding [Menu.View.Language]}">
                        <MenuItem Header="{Binding [Menu.View.Language.French]}" Click="OnFrenchLanguageClick"/>
                        <MenuItem Header="{Binding [Menu.View.Language.English]}" Click="OnEnglishLanguageClick"/>
                    </MenuItem>
                </MenuItem>
                <MenuItem Header="{Binding [Menu.Settings]}">
                    <MenuItem Header="{Binding [Menu.Settings.ManageTiers]}" Click="OnTierConfigClick"/>
                </MenuItem>
            </Menu>

            <!-- Toolbar -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5" Spacing="5" x:Name="Toolbar" DataContext="{x:Static services:LocalizationService.Instance}">
                <Button Content="{Binding [Toolbar.OU], StringFormat='📁 {0}'}" Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).AddOrganizationalUnitCommand}" 
                        ToolTip.Tip="Ajouter une Unité Organisationnelle" Padding="10,5"/>
                <Button Content="{Binding [Toolbar.Container], StringFormat='📦 {0}'}" Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).AddContainerCommand}" 
                        ToolTip.Tip="Ajouter un Container" Padding="10,5"/>
                <Button Content="{Binding [Toolbar.User], StringFormat='👤 {0}'}" Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).AddUserCommand}" 
                        ToolTip.Tip="Ajouter un Utilisateur" Padding="10,5"/>
                <Button Content="{Binding [Toolbar.Group], StringFormat='👥 {0}'}" Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).AddGroupCommand}" 
                        ToolTip.Tip="Ajouter un Groupe" Padding="10,5"/>
                <Button Content="{Binding [Toolbar.Computer], StringFormat='💻 {0}'}" Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).AddComputerCommand}" 
                        ToolTip.Tip="Ajouter un Ordinateur" Padding="10,5"/>
                <Button Content="{Binding [Toolbar.GMSA], StringFormat='🔐 {0}'}" Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).AddGMSACommand}" 
                        ToolTip.Tip="Ajouter un GMSA" Padding="10,5"/>
                <Button Content="{Binding [Toolbar.Policy], StringFormat='📋 {0}'}" Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).AddPolicyCommand}" 
                        ToolTip.Tip="Ajouter une Policy" Padding="10,5"/>
                <Button Content="{Binding [Toolbar.PSO], StringFormat='🔑 {0}'}" Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).AddPasswordSettingsObjectCommand}" 
                        ToolTip.Tip="Ajouter un Password Settings Object" Padding="10,5"/>
                <Separator Width="1" Height="30"/>
                <Button Content="🗑️ Supprimer" Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).DeleteObjectCommand}" 
                        ToolTip.Tip="Supprimer l'objet sélectionné" Padding="10,5"/>
            </StackPanel>
        </Grid>

        <!-- Zone principale : TreeView + Détails -->
        <Grid Grid.Row="1" ColumnDefinitions="400,5,*">
            <!-- TreeView -->
            <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Padding="5">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0" Text="Structure Active Directory" 
                               FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                    <TreeView Grid.Row="1" 
                              ItemsSource="{Binding RootNodes}"
                              SelectedItem="{Binding SelectedNode, Mode=TwoWay}">
                        <TreeView.ItemTemplate>
                            <TreeDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <TextBlock Text="{Binding Icon}" FontSize="16"/>
                                    <TextBlock Text="{Binding Data.Name}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Data.Tier}" 
                                               Foreground="{Binding TierColor}"
                                               FontSize="10" VerticalAlignment="Center"/>
                                </StackPanel>
                            </TreeDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>
            </Border>

            <!-- Séparateur -->
            <GridSplitter Grid.Column="1" Background="LightGray" ResizeDirection="Columns"/>

            <!-- Panneau de détails -->
            <Border Grid.Column="2" BorderBrush="Gray" BorderThickness="1" Padding="10">
                <ScrollViewer>
                    <StackPanel Spacing="10">
                        <TextBlock Text="Détails de l'objet" FontWeight="Bold" FontSize="16"/>

                        <StackPanel Spacing="5">
                            <TextBlock Text="Nom :" FontWeight="SemiBold"/>
                            <TextBox Text="{Binding SelectedObjectName, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel Spacing="5">
                            <TextBlock Text="Type :" FontWeight="SemiBold"/>
                            <TextBox Text="{Binding SelectedObjectType}" IsReadOnly="True"/>
                        </StackPanel>

                        <StackPanel Spacing="5">
                            <TextBlock Text="Distinguished Name :" FontWeight="SemiBold"/>
                            <TextBox Text="{Binding SelectedObjectDistinguishedName}" 
                                     IsReadOnly="True" TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Spacing="5">
                            <TextBlock Text="Tier :" FontWeight="SemiBold"/>
                            <ComboBox SelectedItem="{Binding SelectedObjectTier, Mode=TwoWay}"
                                      ItemsSource="{Binding AvailableTiers}"
                                      Width="200" HorizontalAlignment="Left"/>
                        </StackPanel>

                        <Separator/>

                        <StackPanel Spacing="5">
                            <DockPanel>
                                <TextBlock Text="Description (Markdown) :" FontWeight="SemiBold" 
                                           DockPanel.Dock="Left"/>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="5">
                                    <Button Command="{Binding ToggleMarkdownEditCommand}"
                                            HorizontalAlignment="Right"
                                            Padding="8,4">
                                        <StackPanel Orientation="Horizontal" Spacing="3">
                                            <TextBlock Text="{Binding IsMarkdownEditMode}" IsVisible="False"/>
                                            <TextBlock Text="✏️ Éditer" IsVisible="{Binding !IsMarkdownEditMode}"/>
                                            <TextBlock Text="📖 Prévisualiser" IsVisible="{Binding IsMarkdownEditMode}"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </DockPanel>

                            <TextBox Text="{Binding SelectedObjectDescription, Mode=TwoWay}" 
                                     AcceptsReturn="True" 
                                     TextWrapping="Wrap"
                                     Height="300"
                                     IsVisible="{Binding IsMarkdownEditMode}"/>

                            <Border BorderBrush="LightGray" BorderThickness="1" 
                                    Padding="10" Height="300"
                                    IsVisible="{Binding !IsMarkdownEditMode}">
                                <ScrollViewer>
                                    <ContentControl Content="{Binding SelectedObjectDescription, Converter={StaticResource MarkdownConverter}}"/>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>

                        <Separator/>

                        <StackPanel Spacing="5">
                            <TextBlock Text="Actions :" FontWeight="SemiBold"/>
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <Button Content="Renommer" Command="{Binding RenameObjectCommand}" Padding="10,5"/>
                                <Button Content="Copier" Command="{Binding CopyObjectCommand}" Padding="10,5"/>
                                <Button Content="Supprimer" Command="{Binding DeleteObjectCommand}" 
                                        Padding="10,5" Background="#FFDDDD"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Barre d'état -->
        <Grid Grid.Row="2" Height="30" ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" 
                       VerticalAlignment="Center" Margin="10,0"/>
            <TextBlock Grid.Column="1" Text="{Binding ObjectCountsSummary}" 
                       VerticalAlignment="Center" Margin="10,0" FontSize="11"/>
        </Grid>
    </Grid>
</Window>
