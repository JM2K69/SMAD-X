<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Activedirectory.ViewModels"
        xmlns:services="using:Activedirectory.Services"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="800"
        x:Class="Activedirectory.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:Name="MainWindowRoot"
        Icon="/Assets/avalonia-logo.ico"
        Title="Active Directory Simulator"
        Width="1400" Height="855">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Menu et Toolbar -->
        <Grid Grid.Row="0" RowDefinitions="Auto,Auto">
            <!-- Menu principal -->
            <Menu Grid.Row="0" x:Name="MainMenu" DataContext="{x:Static services:LocalizationService.Instance}">
                <MenuItem Header="{Binding [Menu.File]}">
                    <MenuItem Header="{Binding [Menu.File.NewDomain]}" Command="{Binding #MainWindowRoot.DataContext.CreateNewDomainCommand}" InputGesture="Ctrl+N"/>
                    <MenuItem Header="{Binding [Menu.File.NewStructure]}" Command="{Binding #MainWindowRoot.DataContext.InitializeSampleDataCommand}" InputGesture="Ctrl+Shift+N"/>
                    <Separator/>
                    <MenuItem Header="{Binding [Menu.File.Open]}" Command="{Binding #MainWindowRoot.DataContext.LoadFromFileCommand}" InputGesture="Ctrl+O"/>
                    <MenuItem Header="{Binding [Menu.File.Save]}" Command="{Binding #MainWindowRoot.DataContext.SaveToFileCommand}" InputGesture="Ctrl+S"/>
                    <Separator/>
                    <MenuItem Header="{Binding [Menu.File.ExportJson]}" Command="{Binding #MainWindowRoot.DataContext.ExportToJsonCommand}" InputGesture="Ctrl+E"/>
                    <MenuItem Header="{Binding [Menu.File.ExportPowerShell]}" Command="{Binding #MainWindowRoot.DataContext.ExportToPowerShellCommand}" InputGesture="Ctrl+P"/>
                    <Separator/>
                    <MenuItem Header="{Binding [Menu.File.Exit]}" Click="OnExitClick" InputGesture="Alt+F4"/>
                </MenuItem>
                <MenuItem Header="{Binding [Menu.Edit]}">
                    <MenuItem Header="{Binding [Menu.Edit.Copy]}" Command="{Binding #MainWindowRoot.DataContext.CopyObjectCommand}" InputGesture="Ctrl+C"/>
                    <MenuItem Header="{Binding [Menu.Edit.Paste]}" Command="{Binding #MainWindowRoot.DataContext.PasteObjectCommand}" InputGesture="Ctrl+V"/>
                    <Separator/>
                    <MenuItem Header="{Binding [Menu.Edit.Rename]}" Command="{Binding #MainWindowRoot.DataContext.RenameObjectCommand}" InputGesture="F2"/>
                    <MenuItem Header="{Binding [Menu.Edit.Delete]}" Command="{Binding #MainWindowRoot.DataContext.DeleteObjectCommand}" InputGesture="Delete"/>
                    <Separator/>
                    <MenuItem Header="{Binding [Menu.Edit.AddPSO]}" Command="{Binding #MainWindowRoot.DataContext.AddPasswordSettingsObjectCommand}"/>
                </MenuItem>
                <MenuItem Header="{Binding [Menu.View]}">
                    <MenuItem Header="{Binding [Menu.View.ExpandAll]}" Command="{Binding #MainWindowRoot.DataContext.ExpandAllCommand}"/>
                    <MenuItem Header="{Binding [Menu.View.CollapseAll]}" Command="{Binding #MainWindowRoot.DataContext.CollapseAllCommand}"/>
                    <Separator/>
                    <MenuItem Header="{Binding [Menu.View.Theme]}">
                        <MenuItem Header="{Binding [Menu.View.Theme.Light]}" Click="OnLightThemeClick"/>
                        <MenuItem Header="{Binding [Menu.View.Theme.Dark]}" Click="OnDarkThemeClick"/>
                    </MenuItem>
                    <MenuItem Header="{Binding [Menu.View.Language]}">
                        <MenuItem Header="{Binding [Menu.View.Language.French]}" Click="OnFrenchLanguageClick"/>
                        <MenuItem Header="{Binding [Menu.View.Language.English]}" Click="OnEnglishLanguageClick"/>
                    </MenuItem>
                </MenuItem>
                <MenuItem Header="{Binding [Menu.Settings]}">
                    <MenuItem Header="{Binding [Menu.Settings.ManageTiers]}" Click="OnTierConfigClick"/>
                </MenuItem>
            </Menu>

            <!-- Toolbar -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5" Spacing="5" x:Name="Toolbar" DataContext="{x:Static services:LocalizationService.Instance}">
                <Button Content="{Binding [Toolbar.OU], StringFormat='📁 {0}'}" Command="{Binding #MainWindowRoot.DataContext.AddOrganizationalUnitCommand}" 
                        ToolTip.Tip="Ajouter une Unité Organisationnelle" Padding="10,5"/>
                <Button Content="{Binding [Toolbar.Container], StringFormat='📦 {0}'}" Command="{Binding #MainWindowRoot.DataContext.AddContainerCommand}" 
                        ToolTip.Tip="Ajouter un Container" Padding="10,5"/>
                <Button Content="{Binding [Toolbar.User], StringFormat='👤 {0}'}" Command="{Binding #MainWindowRoot.DataContext.AddUserCommand}" 
                        ToolTip.Tip="Ajouter un Utilisateur" Padding="10,5"/>
                <Button Content="{Binding [Toolbar.Group], StringFormat='👥 {0}'}" Command="{Binding #MainWindowRoot.DataContext.AddGroupCommand}" 
                        ToolTip.Tip="Ajouter un Groupe" Padding="10,5"/>
                <Button Content="{Binding [Toolbar.Computer], StringFormat='💻 {0}'}" Command="{Binding #MainWindowRoot.DataContext.AddComputerCommand}" 
                        ToolTip.Tip="Ajouter un Ordinateur" Padding="10,5"/>
                <Button Content="{Binding [Toolbar.GMSA], StringFormat='🔐 {0}'}" Command="{Binding #MainWindowRoot.DataContext.AddGMSACommand}" 
                        ToolTip.Tip="Ajouter un GMSA" Padding="10,5"/>
                <Button Content="{Binding [Toolbar.Policy], StringFormat='📋 {0}'}" Command="{Binding #MainWindowRoot.DataContext.AddPolicyCommand}" 
                        ToolTip.Tip="Ajouter une Policy" Padding="10,5"/>
                <Button Content="{Binding [Toolbar.PSO], StringFormat='🔑 {0}'}" Command="{Binding #MainWindowRoot.DataContext.AddPasswordSettingsObjectCommand}" 
                        ToolTip.Tip="Ajouter un Password Settings Object" Padding="10,5"/>
                <Separator Width="1" Height="30"/>
                <Button Content="🗑️ Supprimer" Command="{Binding #MainWindowRoot.DataContext.DeleteObjectCommand}" 
                        ToolTip.Tip="Supprimer l'objet sélectionné" Padding="10,5"/>
            </StackPanel>
        </Grid>

        <!-- Zone principale : TreeView + Détails -->
        <Grid Grid.Row="1" ColumnDefinitions="400,5,*">
            <!-- TreeView -->
            <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Padding="5">
                <Grid RowDefinitions="Auto,*" DataContext="{x:Static services:LocalizationService.Instance}">
                    <TextBlock Grid.Row="0" Text="{Binding [TreeView.Title]}" 
                               FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                    <TreeView Grid.Row="1" 
                              ItemsSource="{Binding #MainWindowRoot.DataContext.RootNodes}"
                              SelectedItem="{Binding #MainWindowRoot.DataContext.SelectedNode, Mode=TwoWay}">
                        <TreeView.ItemTemplate>
                            <TreeDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <TextBlock Text="{Binding Icon}" FontSize="16"/>
                                    <TextBlock Text="{Binding Data.Name}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Data.Tier}" 
                                               Foreground="{Binding TierColor}"
                                               FontSize="10" VerticalAlignment="Center"/>
                                </StackPanel>
                            </TreeDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>
            </Border>

            <!-- Séparateur -->
            <GridSplitter Grid.Column="1" Background="LightGray" ResizeDirection="Columns"/>

            <!-- Panneau de détails -->
            <Border Grid.Column="2" BorderBrush="Gray" BorderThickness="1" Padding="10">
                <ScrollViewer>
                    <Grid RowDefinitions="Auto,*">
                        <!-- Titre du panneau de détails avec binding -->
                        <TextBlock Grid.Row="0" 
                                   Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Details.Title]}" 
                                   FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>

                        <StackPanel Grid.Row="1" Spacing="10">
                            <StackPanel Spacing="5">
                                <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Details.Name]}" FontWeight="SemiBold"/>
                                <TextBox Text="{Binding SelectedObjectName, Mode=TwoWay}" />
                            </StackPanel>

                            <StackPanel Spacing="5">
                                <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Details.Type]}" FontWeight="SemiBold"/>
                                <TextBox Text="{Binding SelectedObjectType}" IsReadOnly="True"/>
                            </StackPanel>

                            <StackPanel Spacing="5">
                                <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Details.DN]}" FontWeight="SemiBold"/>
                                <TextBox Text="{Binding SelectedObjectDistinguishedName}" 
                                         IsReadOnly="True" TextWrapping="Wrap"/>
                            </StackPanel>

                            <StackPanel Spacing="5">
                                <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Details.Tier]}" FontWeight="SemiBold"/>
                                <ComboBox SelectedItem="{Binding SelectedObjectTier, Mode=TwoWay}"
                                          ItemsSource="{Binding AvailableTiers}"
                                          Width="200" HorizontalAlignment="Left"/>
                            </StackPanel>

                                            <Separator/>

                                            <StackPanel Spacing="5">
                                                <DockPanel>
                                                    <TextBlock Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[Details.Description]}" FontWeight="SemiBold" 
                                                               DockPanel.Dock="Left"/>
                                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="5" 
                                                                DataContext="{x:Static services:LocalizationService.Instance}">
                                                        <Button Command="{Binding #MainWindowRoot.DataContext.ToggleMarkdownEditCommand}"
                                                                HorizontalAlignment="Right"
                                                                Padding="8,4">
                                                            <StackPanel Orientation="Horizontal" Spacing="3">
                                                                <TextBlock Text="{Binding #MainWindowRoot.DataContext.IsMarkdownEditMode}" IsVisible="False"/>
                                                                <TextBlock Text="{Binding [Details.Edit]}" IsVisible="{Binding #MainWindowRoot.DataContext.IsMarkdownEditMode, Converter={x:Static BoolConverters.Not}}"/>
                                                                <TextBlock Text="{Binding [Details.Preview]}" IsVisible="{Binding #MainWindowRoot.DataContext.IsMarkdownEditMode}"/>
                                                            </StackPanel>
                                                        </Button>
                                                    </StackPanel>
                                                </DockPanel>

                                                <TextBox Text="{Binding SelectedObjectDescription, Mode=TwoWay}" 
                                                         AcceptsReturn="True" 
                                                         TextWrapping="Wrap"
                                                         Height="300"
                                                         IsVisible="{Binding IsMarkdownEditMode}"/>

                                                <Border BorderBrush="LightGray" BorderThickness="1" 
                                                        Padding="10" Height="300"
                                                        IsVisible="{Binding !IsMarkdownEditMode}">
                                                    <ScrollViewer>
                                                        <ContentControl Content="{Binding SelectedObjectDescription, Converter={StaticResource MarkdownConverter}}"/>
                                                    </ScrollViewer>
                                                </Border>
                                            </StackPanel>

                                            <Separator/>

                                            <StackPanel Spacing="5" DataContext="{x:Static services:LocalizationService.Instance}">
                                                <TextBlock Text="{Binding [Details.Actions]}" FontWeight="SemiBold"/>
                                                <StackPanel Orientation="Horizontal" Spacing="5">
                                                    <Button Content="{Binding [Action.Rename]}" Command="{Binding #MainWindowRoot.DataContext.RenameObjectCommand}" Padding="10,5"/>
                                                    <Button Content="{Binding [Action.Copy]}" Command="{Binding #MainWindowRoot.DataContext.CopyObjectCommand}" Padding="10,5"/>
                                                    <Button Content="{Binding [Action.Delete]}" Command="{Binding #MainWindowRoot.DataContext.DeleteObjectCommand}" 
                                                            Padding="10,5" Background="#FFDDDD"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </ScrollViewer>
                            </Border>
                        </Grid>

        <!-- Barre d'état -->
        <Grid Grid.Row="2" Height="30" ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" 
                       VerticalAlignment="Center" Margin="10,0"/>
            <TextBlock Grid.Column="1" Text="{Binding ObjectCountsSummary}" 
                       VerticalAlignment="Center" Margin="10,0" FontSize="11"/>
        </Grid>
    </Grid>
</Window>
