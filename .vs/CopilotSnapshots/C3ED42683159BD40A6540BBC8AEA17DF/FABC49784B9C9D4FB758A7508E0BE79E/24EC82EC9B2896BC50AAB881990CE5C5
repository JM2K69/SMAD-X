        private void OnTreeItemPointerPressed(object? sender, PointerPressedEventArgs e)
        {
            if (sender is Border border && border.DataContext is ADTreeNode node)
            {
                _draggedNode = node;
                _dragStartPoint = e.GetPosition(border);
                _isDragging = false;
            }
        }

        private void OnTreeItemPointerMoved(object? sender, PointerEventArgs e)
        {
            if (_draggedNode != null && sender is Border border && !_isDragging)
            {
                var currentPoint = e.GetPosition(border);
                var diff = currentPoint - _dragStartPoint;

                if (Math.Abs(diff.X) > 5 || Math.Abs(diff.Y) > 5)
                {
                    _isDragging = true;
                }
            }
        }

        private void OnTreeItemPointerReleased(object? sender, PointerReleasedEventArgs e)
        {
            if (_isDragging && _draggedNode != null && sender is Border border && border.DataContext is ADTreeNode targetNode)
            {
                if (DataContext is MainWindowViewModel vm)
                {
                    // Vérifier que le déplacement est valide
                    if (_draggedNode != targetNode && 
                        !IsDescendantOf(_draggedNode, targetNode) &&
                        CanMoveNodeToTarget(_draggedNode, targetNode))
                    {
                        // Retirer le nœud de son parent actuel
                        var oldParent = _draggedNode.Parent;
                        var draggedData = _draggedNode.Data;

                        if (oldParent != null)
                        {
                            // Retirer du parent
                            oldParent.Children.Remove(_draggedNode);
                            oldParent.Data.Children.Remove(draggedData);
                        }
                        else
                        {
                            // Retirer des racines (le nœud est à la racine)
                            vm.RootNodes.Remove(_draggedNode);
                        }

                        // Ajouter au nouveau parent
                        var newParentData = targetNode.Data;
                        newParentData.Children.Add(draggedData);
                        draggedData.Parent = newParentData;

                        // Mettre à jour le Distinguished Name
                        draggedData.UpdateDistinguishedName();

                        // Mettre à jour récursivement les DN des enfants
                        UpdateChildrenDistinguishedNames(draggedData);

                        // Créer un nouveau nœud et l'ajouter
                        var newNode = new ADTreeNode(draggedData)
                        {
                            Parent = targetNode
                        };
                        targetNode.Children.Add(newNode);

                        // Développer le nœud cible
                        targetNode.IsExpanded = true;

                        // Sélectionner le nœud déplacé
                        vm.SelectedNode = newNode;
                    }
                }
            }

            _draggedNode = null;
            _isDragging = false;
        }

        private void UpdateChildrenDistinguishedNames(ADObject obj)
        {
            foreach (var child in obj.Children)
            {
                child.UpdateDistinguishedName();
                UpdateChildrenDistinguishedNames(child);
            }
        }

        private bool IsDescendantOf(ADTreeNode node, ADTreeNode potentialAncestor)
        {
            var current = potentialAncestor.Parent;
            while (current != null)
            {
                if (current == node)
                    return true;
                current = current.Parent;
            }
            return false;
        }

        private bool CanMoveNodeToTarget(ADTreeNode draggedNode, ADTreeNode targetNode)
        {
            var draggedType = draggedNode.Data.Type;
            var targetType = targetNode.Data.Type;

            // Règles de validation basées sur ADValidationService
            return targetType switch
            {
                ADObjectType.Domain => draggedType is ADObjectType.OrganizationalUnit or ADObjectType.Policy,
                ADObjectType.OrganizationalUnit => draggedType is not ADObjectType.Domain,
                _ => false
            };
        }
