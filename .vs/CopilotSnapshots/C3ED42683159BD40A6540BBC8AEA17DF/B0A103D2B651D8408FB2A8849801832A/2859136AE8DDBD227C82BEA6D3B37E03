<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Activedirectory.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
        x:Class="Activedirectory.Views.TierConfigurationWindow"
        x:DataType="vm:TierConfigurationViewModel"
        Title="Configuration des Tiers"
        Width="800" Height="600"
        WindowStartupLocation="CenterOwner">

    <Design.DataContext>
        <vm:TierConfigurationViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto" Margin="20">
        <!-- Titre -->
        <TextBlock Grid.Row="0" Text="Gestion des Tiers de Sécurité" 
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Contenu principal -->
        <Grid Grid.Row="1" ColumnDefinitions="*,20,*">
            <!-- Liste des tiers existants -->
            <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Padding="10">
                <Grid RowDefinitions="Auto,*,Auto">
                    <TextBlock Grid.Row="0" Text="Tiers existants" 
                               FontWeight="SemiBold" Margin="0,0,0,10"/>

                    <ListBox Grid.Row="1" ItemsSource="{Binding Tiers}"
                             SelectedItem="{Binding SelectedTier, Mode=TwoWay}"
                             Margin="0,0,0,10"
                             x:Name="TiersListBox">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="LightGray" BorderThickness="1" 
                                        Padding="10" Margin="0,5"
                                        PointerPressed="OnItemPointerPressed"
                                        PointerMoved="OnItemPointerMoved"
                                        PointerReleased="OnItemPointerReleased"
                                        DragDrop.AllowDrop="True">
                                    <Grid RowDefinitions="Auto,Auto,Auto">
                                        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10">
                                            <TextBlock Text="⠿" FontSize="16" 
                                                       VerticalAlignment="Center" 
                                                       Foreground="Gray" Cursor="Hand"/>
                                            <TextBlock Text="{Binding Name}" 
                                                       FontWeight="Bold" FontSize="14"/>
                                            <Border Width="30" Height="20" 
                                                    Background="{Binding Color}"
                                                    BorderBrush="Black" BorderThickness="1"/>
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" Text="{Binding Description}" 
                                                   TextWrapping="Wrap" Margin="0,5,0,0"
                                                   FontSize="12" Foreground="Gray"/>
                                        <TextBlock Grid.Row="2" 
                                                   Text="{Binding Level, StringFormat='Niveau : {0}'}"
                                                   FontSize="11" Foreground="DarkGray" Margin="0,3,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10">
                        <Button Content="Supprimer" Command="{Binding RemoveTierCommand}"
                                IsEnabled="{Binding SelectedTier, Converter={x:Static ObjectConverters.IsNotNull}}"
                                Padding="15,5"/>
                        <Button Content="Réinitialiser" Command="{Binding ResetToDefaultsCommand}"
                                Padding="15,5"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Ajout d'un nouveau tier -->
            <Border Grid.Column="2" BorderBrush="Gray" BorderThickness="1" Padding="10">
                <Grid RowDefinitions="Auto,*,Auto">
                    <TextBlock Grid.Row="0" Text="Ajouter un nouveau tier" 
                               FontWeight="SemiBold" Margin="0,0,0,10"/>

                    <StackPanel Grid.Row="1" Spacing="15">
                        <StackPanel Spacing="5">
                            <TextBlock Text="Nom :" FontWeight="SemiBold"/>
                            <TextBox Text="{Binding NewTierName, Mode=TwoWay}"
                                     PlaceholderText="Ex: Tier 3"/>
                        </StackPanel>

                        <StackPanel Spacing="5">
                            <TextBlock Text="Couleur (hex) :" FontWeight="SemiBold"/>
                            <Grid ColumnDefinitions="*,50,100">
                                <TextBox Grid.Column="0" Text="{Binding NewTierColor, Mode=TwoWay}"
                                         PlaceholderText="#RRGGBB"/>
                                <Border Grid.Column="1" Background="{Binding NewTierColor}"
                                        BorderBrush="Black" BorderThickness="1" Margin="5,0"/>
                                <Button Grid.Column="2" Content="🎨 Sélectionner" 
                                        Click="OnSelectColorClick" Padding="5"/>
                            </Grid>
                            <TextBlock Text="Exemples : #FF0000 (rouge), #00FF00 (vert), #0000FF (bleu)"
                                       FontSize="10" Foreground="Gray"/>
                        </StackPanel>

                        <StackPanel Spacing="5">
                            <TextBlock Text="Description :" FontWeight="SemiBold"/>
                            <TextBox Text="{Binding NewTierDescription, Mode=TwoWay}"
                                     AcceptsReturn="True" Height="80" TextWrapping="Wrap"
                                     PlaceholderText="Description du tier..."/>
                        </StackPanel>

                        <StackPanel Spacing="5">
                            <TextBlock Text="Niveau de priorité :" FontWeight="SemiBold"/>
                            <NumericUpDown Value="{Binding NewTierLevel, Mode=TwoWay}"
                                          Minimum="0" Maximum="99" Width="150"
                                          HorizontalAlignment="Left"/>
                            <TextBlock Text="Plus le niveau est bas, plus la priorité est élevée"
                                       FontSize="10" Foreground="Gray"/>
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Row="2" Content="Ajouter" Command="{Binding AddTierCommand}"
                            HorizontalAlignment="Stretch" Padding="15,8"
                            Margin="0,10,0,0"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Boutons de bas de page -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Spacing="10" Margin="0,20,0,0">
            <Button Content="Fermer" Click="OnCloseClick" Padding="20,8"/>
        </StackPanel>
    </Grid>
</Window>
